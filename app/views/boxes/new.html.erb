<% content_for :title, "Nouvelle boîte · RE-PLAY" %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <%= link_to boxes_path, class: "btn-back-boxes" do %>
      <span style="color:#000;">←</span>
      <i class="fa-solid fa-boxes-stacked"></i>
    <% end %>
  </div>

  <div class="detail-card p-4">
    <div class="d-flex align-items-center gap-3 mb-3">
      <div class="form-card-icon" style="margin-bottom:0; flex-shrink:0;">
        <i class="fa-solid fa-plus"></i>
      </div>
      <h1 class="toy-show-title" style="font-size:1.6rem;">Nouvelle boîte</h1>
    </div>

    <%= simple_form_for @box do |f| %>
      <%= hidden_field_tag :new_flow, true %>

      <div style="font-size:0.9rem; font-weight:600; color:#9CA3AF; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.5rem;">Catégorie de jouets</div>
      <div class="mb-4">
        <%= f.association :category,
            label: false,
            prompt: "Choisir une catégorie…",
            input_html: { class: "form-select verify-select" } %>
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-primary btn-lg">
          <i class="fa-solid fa-arrow-right" style="font-size:1.5rem;"></i>
        </button>
      </div>
    <% end %>
  </div>
</div>
