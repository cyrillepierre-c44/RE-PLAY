<% content_for :title, "Modifier la boîte ##{@box.id} · RE-PLAY" %>

<div class="form-page">
  <div class="container">
    <%= link_to box_path(@box), class: "btn btn-ghost btn-sm mb-3" do %>
      <i class="fa-solid fa-arrow-left me-1"></i> Retour à la boîte
    <% end %>
    <div class="form-card">
      <div class="form-card-header">
        <div class="form-card-icon">
          <i class="fa-solid fa-pen-to-square"></i>
        </div>
        <h1 class="form-card-title">Modifier la boîte #<%= @box.id %></h1>
        <p class="form-card-subtitle">Mettez à jour les informations de cette boîte</p>
      </div>
      <div class="form-card-body">
        <%= render "form" %>
      </div>
    </div>
  </div>
</div>
