<% content_for :title, "#{params[:new] ? 'Nouvelle' : 'Modifier'} boîte N°#{@box.id} · RE-PLAY" %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <% if params[:new] %>
      <%= link_to boxes_path, class: "btn-back-boxes" do %>
        <i class="fa-solid fa-circle-arrow-left" style="font-size:1.8rem;"></i>
        <i class="fa-solid fa-boxes-stacked btn-back-context-icon" style="font-size:1.8rem;"></i>
      <% end %>
    <% else %>
      <%= link_to box_path(@box), class: "btn-back-boxes" do %>
        <i class="fa-solid fa-circle-arrow-left" style="font-size:1.8rem;"></i>
        <i class="fa-solid fa-box btn-back-context-icon" style="font-size:1.8rem;"></i>
      <% end %>
    <% end %>
    <span class="toy-show-category-badge" style="font-size:2rem; max-width:none;"><i class="fa-solid fa-box me-1"></i>N°&nbsp;<%= @box.id %></span>
  </div>

  <% if params[:new] %>
    <div class="d-flex align-items-center justify-content-center gap-3 mb-3 p-3" style="background:linear-gradient(135deg,rgba(255,107,53,0.08),rgba(255,107,53,0.04)); border-radius:1rem; border:2px dashed rgba(255,107,53,0.35);">
      <div style="text-align:center;">
        <div style="font-size:0.8rem; font-weight:600; color:#9CA3AF; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.2rem;">Étiqueter la boîte</div>
        <div style="font-size:2.8rem; font-weight:900; color:#FF6B35; line-height:1;">N°&nbsp;<%= @box.id %></div>
      </div>
      <i class="fa-solid fa-tag" style="font-size:2rem; color:rgba(255,107,53,0.4);"></i>
    </div>
  <% end %>

  <div class="detail-card p-4">
    <div class="d-flex align-items-center gap-3 mb-1">
      <h1 class="toy-show-title" style="font-size:1.6rem;"><%= params[:new] ? 'Nouvelle boîte' : 'Modifier la boîte' %> N°<%= @box.id %></h1>
    </div>
    <p style="font-size:1.15rem; font-weight:700; color:#1A2B4A; margin-bottom:1rem;"><%= @box.category.name %></p>

    <%= simple_form_for @box do |f| %>

      <%# Catégorie — visible uniquement en edit classique %>
      <% unless params[:new] %>
        <div class="mb-2">
          <%= f.association :category,
              label: false,
              prompt: "Catégorie…",
              input_html: { class: "form-select verify-select" } %>
        </div>
      <% end %>

      <%# Électronique %>
      <div class="verify-conditions mb-2">
        <%= f.check_box :electronic, class: "condition-toggle-input", id: "box_electronic" %>
        <%= f.label :electronic, class: "condition-toggle-label", for: "box_electronic" do %>
          <i class="fa-solid fa-bolt"></i>
          <span>Électronique</span>
        <% end %>
      </div>

      <%# Poids %>
      <div class="mb-3">
        <div style="font-size:0.75rem; color:#9CA3AF; margin-bottom:0.2rem;">Facultatif</div>
        <%= f.input :weight, label: false, as: :numeric,
            input_html: { class: "form-control verify-input", step: 0.1, placeholder: "Poids (kg)" } %>
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-primary btn-lg">
          <i class="fa-solid fa-check" style="font-size:1.5rem;"></i>
        </button>
      </div>

    <% end %>
  </div>
</div>
