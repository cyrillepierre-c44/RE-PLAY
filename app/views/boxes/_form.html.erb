<div class="request-form">
  <%= simple_form_for @box do |f| %>
<div class="mb-3">
  <%= f.input :category_id,
    label: "Catégorie",
    collection: Category.all,
    prompt: "Choisir une catégorie de jouets à l'intérieur",
    input_html: { class: "form-select" } %>
</div>

    <div class="mb-3 form-check">
      <%= f.input :electronic,
        label: "Cocher si la boite ne contiendra que des jouets électroniques",
        input_html: { class: "form-check-input" },
        wrapper_html: { class: "form-check" } %>
    </div>

<div class="mb-3">
  <%= f.input :weight,
    label: "Poids (kg)",
    as: :numeric,
    input_html: { class: "form-control", step: 0.1 } %>
    </div>

    <div class="d-grid gap-2">
      <%= f.button :submit, "Soumettre", class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
