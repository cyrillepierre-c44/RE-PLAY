<%= simple_form_for @box do |f| %>
  <div class="mb-3">
    <%= f.input :category_id,
      label: "Catégorie de jouets",
      collection: Category.all,
      prompt: "Choisir une catégorie...",
      input_html: { class: "form-select" },
      label_html: { class: "form-label" } %>
  </div>

  <div class="mb-3">
    <label class="form-label">Type de contenu</label>
    <div class="form-check-custom">
      <%= f.check_box :electronic, class: "form-check-input", id: "box_electronic" %>
      <%= f.label :electronic, class: "form-check-label", for: "box_electronic" do %>
        <i class="fa-solid fa-microchip" style="color:#FF6B35;"></i>
        Boîte de jouets électroniques uniquement
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.input :weight,
      label: "Poids estimé (kg)",
      as: :numeric,
      input_html: { class: "form-control", step: 0.1, placeholder: "Ex: 3.5" },
      label_html: { class: "form-label" } %>
  </div>

  <div class="d-grid">
    <%= f.button :submit, class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
