<% content_for :title, "Caisses · RE-PLAY" %>

<div class="container py-4">
  <div class="page-header">
    <div>
      <h1 class="page-title"><i class="fa-solid fa-boxes-stacked me-2" style="color:#FF6B35;"></i>Caisses</h1>
      <p class="page-subtitle">
        <% if params[:filter] == 'empty' %>
          Caisses vidées
        <% elsif params[:filter] == 'suppr' %>
          Caisses jetées
        <% else %>
          Caisses en cours de traitement
        <% end %>
      </p>
    </div>
    <%= link_to new_box_path, class: "btn-new-box", title: "Nouvelle caisse" do %>
      <i class="fa-solid fa-plus"></i>
    <% end %>
  </div>

  <div class="mb-3">
    <%= form_with url: boxes_path, method: :get, local: true do |f| %>
      <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
      <div class="input-group search-id-group">
        <span class="input-group-text search-id-prefix">C</span>
        <%= f.text_field :q,
              value: params[:q].to_s.gsub(/\D/, ''),
              placeholder: "Numéro de caisse",
              inputmode: "numeric",
              pattern: "[0-9]*",
              autocomplete: "off",
              class: "form-control search-id-input" %>
        <% if params[:q].present? %>
          <%= link_to boxes_path(category_id: params[:category_id]),
                class: "btn search-id-clear" do %>
            <i class="fa-solid fa-xmark"></i>
          <% end %>
        <% end %>
        <button type="submit" class="btn search-id-submit">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <div class="filter-tabs filter-tabs-boxes">
      <% f = @active_filter || params[:filter] %>
      <%= link_to boxes_path(category_id: params[:category_id]),
            class: "filter-tab filter-tab-box-active filter-tab-full #{'active' unless f.in?(%w[suppr empty])}" do %>
        <i class="fa-solid fa-box"></i>
        En cours
        <span class="filter-count"><%= @count_scope.active.count %></span>
      <% end %>
      <div class="filter-tabs-sub-row">
        <%= link_to boxes_path(filter: "empty", category_id: params[:category_id]),
              class: "filter-tab filter-tab-box-empty #{'active' if f == 'empty'}" do %>
          <i class="fa-solid fa-box-open"></i>
          Vides
          <span class="filter-count"><%= @count_scope.empty.count %></span>
        <% end %>
        <%= link_to boxes_path(filter: "suppr", category_id: params[:category_id]),
              class: "filter-tab filter-tab-box-suppr #{'active' if f == 'suppr'}" do %>
          <i class="fa-solid fa-dumpster"></i>
          Jetées
          <span class="filter-count"><%= @count_scope.suppr.count %></span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mb-4">
    <%= form_with url: boxes_path, method: :get, local: true do |f| %>
      <%= hidden_field_tag :filter, params[:filter] %>
      <%= f.select :category_id,
            options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
            { include_blank: "Toutes les catégories" },
            { class: "form-select category-filter-select", onchange: "this.form.requestSubmit()" } %>
    <% end %>
  </div>

  <% if @boxes.empty? %>
    <div class="text-center py-5">
      <div style="font-size: 4rem; color: rgba(255,107,53,0.2); margin-bottom: 1rem;">
        <i class="fa-solid fa-boxes-stacked"></i>
      </div>
      <h3 style="color: #6B7280;">Aucune caisse ici</h3>
      <% unless params[:filter] == 'suppr' %>
        <%= link_to new_box_path, class: "btn btn-primary mt-2" do %>
          <i class="fa-solid fa-plus me-1"></i>Nouvelle caisse
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="row g-3">
      <% @boxes.each do |box| %>
        <div class="col-12 col-sm-6 col-lg-4">
          <%= link_to box_path(box, back_filter: params[:filter]), class: "box-card d-block text-decoration-none" do %>
            <div class="box-card-header">
              <div class="d-flex align-items-center gap-2">
                <% if box.suppr? %>
                  <span class="status-dot status-dot-deleted"></span>
                <% elsif box.empty? %>
                  <span class="status-dot status-dot-empty"></span>
                <% else %>
                  <span class="status-dot status-dot-box-active"></span>
                <% end %>
                <span class="box-card-id">
                  <% if box.suppr? %>
                    <i class="fa-solid fa-dumpster me-1" style="color:#FF6B35; font-size:0.9em;"></i>
                  <% elsif box.empty? %>
                    <i class="fa-solid fa-box-open me-1" style="color:#FF6B35; font-size:0.9em;"></i>
                  <% else %>
                    <i class="fa-solid fa-box me-1" style="color:#FF6B35; font-size:0.9em;"></i>
                  <% end %>
                  C<%= box.id %>
                </span>
              </div>
            </div>
            <div class="box-card-category">
              <i class="fa-solid <%= box.category.icon.presence || 'fa-tag' %> me-1"></i><%= box.category.name %>
            </div>
            <div class="box-card-details">
              <div class="box-card-details-left">
                <% if box.electronic? %>
                  <span class="box-detail-item" title="Électronique">
                    <i class="fa-solid fa-microchip" style="color:#FF6B35; font-size:1.5em;"></i>
                  </span>
                <% end %>
              </div>
              <% if box.nb_toys.present? %>
                <span class="box-toy-count" title="<%= box.nb_toys %> jouet<%= 's' if box.nb_toys > 1 %>">
                  <%= toys_icon %>
                  <%= box.nb_toys %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
