<div class="auth-wrapper">
  <div class="auth-background">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>

  <div class="auth-card-modern">
    <div class="auth-illustration">
      <div class="toy-icon">📦</div>
      <h1>Mes Boites</h1>
      <p>Gérez vos boîtes de jeux</p>
    </div>

    <div class="auth-form">
      <% if @boxes.any? %>
        <div class="items-list">
          <% @boxes.each do |box| %>
            <%= link_to box_path(box), class: "item-card" do %>
              <div class="item-icon">📦</div>
              <div class="item-info">
                <h3>Boite #<%= box.id %></h3>
                <p><%= box.category.name %></p>
                <div class="item-meta">
                  <span class="tag <%= box.electronic ? 'tag-electronic' : 'tag-normal' %>">
                    <%= box.electronic ? '⚡ Électronique' : '🎯 Non électronique' %>
                  </span>
                  <span class="weight"><%= box.weight %> Kg</span>
                </div>
              </div>
              <div class="item-arrow">›</div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <div class="empty-icon">📦</div>
          <p>Aucune boîte pour le moment</p>
        </div>
      <% end %>

      <div class="form-actions">
        <%= link_to new_box_path, class: "btn-modern btn-primary" do %>
          <span class="btn-icon">➕</span>
          Nouvelle boîte
        <% end %>
      </div>

      <div class="auth-footer">
        <%= link_to root_path, class: "back-link" do %>
          <span>←</span> Retour à l'accueil
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  * {
    box-sizing: border-box;
  }

  .auth-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    font-family: 'Poppins', sans-serif;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .auth-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
    animation: float 6s ease-in-out infinite;
  }

  .shape-1 {
    width: 300px;
    height: 300px;
    background: white;
    top: -100px;
    left: -100px;
    animation-delay: 0s;
  }

  .shape-2 {
    width: 200px;
    height: 200px;
    background: #FFD700;
    bottom: -50px;
    right: -50px;
    animation-delay: 2s;
  }

  .shape-3 {
    width: 150px;
    height: 150px;
    background: #FF6B6B;
    top: 50%;
    right: 10%;
    animation-delay: 4s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }

  .auth-card-modern {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    width: 100%;
    max-width: 500px;
    z-index: 1;
    overflow: hidden;
  }

  .auth-illustration {
    background: linear-gradient(135deg, #FF9A56 0%, #FF6B6B 50%, #FF8E53 100%);
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    position: relative;
  }

  .auth-illustration::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.5;
  }

  .toy-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: bounce 2s ease-in-out infinite;
    position: relative;
    z-index: 1;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .auth-illustration h1 {
    color: white;
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .auth-illustration p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .auth-form {
    padding: 2rem;
  }

  .items-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
    max-height: 400px;
    overflow-y: auto;
  }

  .item-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid transparent;
  }

  .item-card:hover {
    background: white;
    border-color: #FF9A56;
    transform: translateX(5px);
    box-shadow: 0 4px 15px rgba(255, 154, 86, 0.2);
  }

  .item-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .item-info {
    flex: 1;
    min-width: 0;
  }

  .item-info h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
  }

  .item-info p {
    margin: 0.25rem 0;
    font-size: 0.9rem;
    color: #666;
  }

  .item-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    font-weight: 500;
  }

  .tag-electronic {
    background: #FEF3C7;
    color: #D97706;
  }

  .tag-normal {
    background: #D1FAE5;
    color: #059669;
  }

  .weight {
    font-size: 0.8rem;
    color: #999;
    font-weight: 500;
  }

  .item-arrow {
    font-size: 1.5rem;
    color: #ccc;
    font-weight: 300;
  }

  .empty-state {
    text-align: center;
    padding: 2rem;
    color: #999;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .btn-modern {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 16px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 14px;
    background: linear-gradient(135deg, #FF9A56 0%, #FF6B6B 100%);
    border: none;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
    text-decoration: none;
  }

  .btn-modern:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(255, 107, 107, 0.4);
    color: white;
  }

  .btn-icon {
    font-size: 1.2rem;
  }

  .auth-footer {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px dashed #eee;
    text-align: center;
  }

  .back-link {
    color: #FF6B6B;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .back-link:hover {
    color: #FF8E53;
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .auth-card-modern {
      border-radius: 20px;
    }

    .auth-illustration {
      padding: 2rem 1.5rem 1.5rem;
    }

    .auth-form {
      padding: 1.5rem;
    }

    .toy-icon {
      font-size: 3rem;
    }

    .items-list {
      max-height: 300px;
    }
  }
</style>
