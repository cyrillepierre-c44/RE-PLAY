<% content_for :title, "Boîte ##{@box.id} · RE-PLAY" %>

<div class="container py-4">
  <%= link_to boxes_path, class: "btn btn-ghost btn-sm mb-3" do %>
    <i class="fa-solid fa-arrow-left me-1"></i> Retour aux boîtes
  <% end %>

  <div class="row g-4">
    <div class="col-md-5 col-lg-4">
      <div class="detail-card p-4">
        <div style="width:64px; height:64px; border-radius:1rem; background: linear-gradient(135deg, #FFF4EC, #FFD6B8);
                    display:flex; align-items:center; justify-content:center;
                    color: #FF6B35; font-size: 1.8rem; margin-bottom: 1.25rem;">
          <i class="fa-solid fa-<%= @box.electronic? ? 'bolt' : 'box-open' %>"></i>
        </div>
        <h1 style="font-size: 2rem; color: #1A2B4A; margin-bottom: 0.25rem;">Boîte #<%= @box.id %></h1>
        <p style="color: #6B7280; font-size: 0.9rem; margin-bottom: 1.25rem;">
          Créée le <%= @box.created_at.strftime('%d/%m/%Y') %>
        </p>

        <div class="d-flex flex-column gap-2 mb-3">
          <div class="d-flex align-items-center gap-2">
            <span style="color: #9CA3AF; font-size: 0.8rem; width: 80px;">Catégorie</span>
            <span class="badge badge-category"><%= @box.category.name %></span>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span style="color: #9CA3AF; font-size: 0.8rem; width: 80px;">Type</span>
            <% if @box.electronic? %>
              <span class="badge badge-electronic"><i class="fa-solid fa-bolt me-1"></i>Électronique</span>
            <% else %>
              <span class="badge badge-condition">Non électronique</span>
            <% end %>
          </div>
          <% if @box.weight.present? %>
            <div class="d-flex align-items-center gap-2">
              <span style="color: #9CA3AF; font-size: 0.8rem; width: 80px;">Poids</span>
              <strong><%= @box.weight %> kg</strong>
            </div>
          <% end %>
          <div class="d-flex align-items-center gap-2">
            <span style="color: #9CA3AF; font-size: 0.8rem; width: 80px;">Jouets</span>
            <strong><%= @box.toys.count %></strong>
          </div>
        </div>

        <div class="action-strip">
          <%= link_to new_box_toy_path(@box), class: "btn btn-primary btn-sm" do %>
            <i class="fa-solid fa-plus me-1"></i>Ajouter un jouet
          <% end %>
          <% if policy(@box).edit? %>
            <%= link_to edit_box_path(@box), class: "btn btn-ghost btn-sm" do %>
              <i class="fa-solid fa-pen me-1"></i>Modifier
            <% end %>
          <% end %>
          <% if policy(@box).destroy? %>
            <%= link_to box_path(@box),
                  class: "btn btn-sm",
                  style: "background: rgba(230,57,70,0.1); color: #E63946; font-weight:700;",
                  data: { turbo_method: :delete, turbo_confirm: "Supprimer cette boîte ?" } do %>
              <i class="fa-solid fa-trash me-1"></i>Supprimer
            <% end %>
          <% end %>
          <%= button_to toggle_empty_box_path(@box), method: :patch, class: "btn btn-sm" do %>
            <% if @box.empty? %>
              <i class="fa-solid fa-box me-1"></i>Marquer non vide
            <% else %>
              <i class="fa-solid fa-box-open me-1"></i>Marquer vide
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-7 col-lg-8">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 style="font-size: 1.2rem; color: #1A2B4A; margin: 0;">
          Jouets dans cette boîte (<%= @box.toys.count %>)
        </h2>
      </div>

      <% if @box.toys.empty? %>
        <div class="detail-card p-4 text-center" style="color: #9CA3AF;">
          <i class="fa-solid fa-puzzle-piece" style="font-size: 2.5rem; color: rgba(255,107,53,0.2); margin-bottom: 0.75rem; display:block;"></i>
          Aucun jouet dans cette boîte.
          <%= link_to "Ajouter le premier jouet", new_box_toy_path(@box), class: "btn btn-primary btn-sm d-block mt-3 mx-auto" , style:"width:fit-content;" %>
        </div>
      <% else %>
        <div class="row g-3">
          <% @box.toys.each do |toy| %>
            <div class="col-sm-6 col-xl-4">
              <div class="toy-card">
                <% if toy.photo.attached? %>
                  <%= image_tag toy.photo, class: "toy-card-img" %>
                <% else %>
                  <div class="toy-card-no-img"><i class="fa-solid fa-image"></i></div>
                <% end %>
                <div class="toy-card-body">
                  <div class="toy-card-title">Jouet #<%= toy.id %></div>
                  <div class="toy-card-meta">
                    <i class="fa-solid fa-tag"></i><%= toy.category.name %>
                  </div>
                  <div class="toy-card-badges">
                    <% if toy.location == "En attente de validation" %>
                      <span class="badge badge-waiting">En attente</span>
                    <% else %>
                      <span class="badge badge-validated">Validé</span>
                    <% end %>
                  </div>
                  <div class="toy-card-actions">
                    <%= link_to toy_path(toy), class: "btn btn-primary btn-sm" do %>
                      Voir
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- ci-dessous la partie du code pour le  tracage des boites -->
  <% if @timeline.any? %>
    <div class="row mt-4">
      <div class="col-12">
        <h3>Historique</h3>
        <ul>
          <% @timeline.each do |action| %>
            <li>
              <%= action.created_at.strftime('%d/%m/%Y à %H:%M') %> —
              <%= action.content %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
