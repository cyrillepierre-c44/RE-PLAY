<% content_for :title, "Caisse C#{@box.id} · RE-PLAY" %>

<div class="container py-4">
  <%= link_to boxes_path(filter: params[:back_filter]), class: "btn-back-boxes mb-3 d-inline-block" do %>
    <i class="fa-solid fa-circle-arrow-left"></i>
    <i class="fa-solid fa-boxes-stacked btn-back-context-icon"></i>
  <% end %>

  <div class="row g-4">
    <%# ── Colonne info caisse ── %>
    <div class="col-12 col-md-4 col-lg-3">
      <div class="detail-card p-4">

        <div class="d-flex align-items-center justify-content-between mb-3">
          <h1 class="toy-show-title">
            <% if @box.suppr? %>
              <i class="fa-solid fa-dumpster me-2"></i>
            <% elsif @box.empty? %>
              <i class="fa-solid fa-box-open me-2"></i>
            <% else %>
              <i class="fa-solid fa-box me-2"></i>
            <% end %>
            C<%= @box.id %>
          </h1>
          <% if policy(@box).toggle_empty? && !@box.suppr? %>
            <%= button_to toggle_empty_box_path(@box), method: :patch, class: "box-toggle-btn" do %>
              <div class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-box box-toggle-icon-left <%= @box.empty? ? 'dimmed' : 'active' %>" title="Pleine"></i>
                <div class="box-toggle-wrap <%= @box.empty? ? 'is-empty' : 'is-full' %>">
                  <div class="box-toggle-track">
                    <div class="box-toggle-thumb"></div>
                  </div>
                </div>
                <i class="fa-solid fa-box-open box-toggle-icon-right <%= @box.empty? ? 'active' : 'dimmed' %>" title="Vide"></i>
              </div>
            <% end %>
          <% end %>
        </div>

        <div class="mb-3">
          <div class="toy-show-info-grid">
            <div class="toy-show-info-item">
              <i class="fa-solid <%= @box.category.icon.presence || 'fa-tag' %>"></i>
              <span><%= truncate(@box.category.name, length: 20) %></span>
            </div>
            <% if @box.nb_toys.present? %>
              <div class="toy-show-info-item">
                <%= toys_icon %>
                <span><%= @box.nb_toys %> jouet<%= 's' if @box.nb_toys > 1 %></span>
              </div>
            <% end %>
            <% if @box.electronic? %>
              <div class="toy-show-info-item">
                <i class="fa-solid fa-microchip" style="color:#FF6B35;"></i>
                <span>Électronique</span>
              </div>
            <% end %>
          </div>
        </div>

        <%# Boutons action %>
        <div class="toy-show-actions">
          <% if @box.pending? %>
            <%= link_to new_box_toy_path(@box), class: "toy-show-btn toy-show-btn-verify", title: "Ajouter un jouet" do %>
              <i class="fa-solid fa-plus"></i>
            <% end %>
            <% unless current_user.admin? %>
              <button type="button"
                      class="toy-show-btn toy-show-btn-delete"
                      title="Jouet à jeter directement"
                      data-bs-toggle="modal"
                      data-bs-target="#quickDiscardModal">
                <i class="fa-solid fa-minus"></i>
              </button>
            <% end %>
          <% end %>
          <% if policy(@box).edit? %>
            <%= link_to edit_box_path(@box), class: "toy-show-btn toy-show-btn-edit", title: "Modifier" do %>
              <i class="fa-solid fa-pen"></i>
            <% end %>
          <% end %>
          <% if policy(@box).destroy? && !@box.suppr? %>
            <%= button_to box_path(@box),
                  method: :delete,
                  class: "toy-show-btn toy-show-btn-delete",
                  title: "Supprimer",
                  form: { style: "display:inline;", data: { turbo_confirm: "Supprimer cette caisse ? Cette action est irréversible." } } do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          <% end %>
          <% if @box.suppr? && policy(@box).restore? %>
            <%= button_to restore_box_path(@box),
                  method: :patch,
                  class: "toy-show-btn toy-show-btn-restore",
                  title: "Remettre en cours",
                  form: { style: "display:inline;" } do %>
              <i class="fa-solid fa-rotate-left"></i>
            <% end %>
          <% end %>
        </div>

      </div>
    </div>

    <%# ── Colonne jouets ── %>
    <div class="col-12 col-md-8 col-lg-9">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="toy-show-title" style="font-size:1.4rem;">
          <%= toys_icon(html_class: "me-2") %><%= @box.toys.count %> jouet<%= 's' if @box.toys.count > 1 %>
        </h2>
      </div>

      <% unless @box.toys.empty? %>
        <div class="row g-3">
          <% @box.toys.order(created_at: :desc).each do |toy| %>
            <div class="col-12 col-sm-6 col-xl-4">
              <%= link_to toy_path(toy), class: "toy-card d-block text-decoration-none #{'toy-card--sold' if toy.sold?}" do %>
                <div class="toy-card-photo-wrap">
                  <% if toy.photo.attached? %>
                    <%= image_tag toy.photo, class: "toy-card-img" %>
                  <% else %>
                    <div class="toy-card-no-img"><i class="fa-solid fa-image"></i></div>
                  <% end %>
                  <% if toy.price.present? %>
                    <div class="toy-card-price-badge"><%= toy.price.to_i %> €</div>
                  <% end %>
                  <% if toy.suppr? %>
                    <span class="status-dot status-dot-deleted toy-card-status-dot" title="Jeté"></span>
                  <% elsif toy.market? %>
                    <span class="status-dot status-dot-validated toy-card-status-dot" title="Validé"></span>
                  <% elsif toy.review? %>
                    <span class="status-dot status-dot-review toy-card-status-dot" title="Contrôle qualité refusé"></span>
                    <div class="toy-card-review-badge">
                      <i class="fa-solid fa-triangle-exclamation"></i> CQ refusé
                    </div>
                  <% else %>
                    <span class="status-dot status-dot-waiting toy-card-status-dot" title="En attente"></span>
                  <% end %>
                  <% if toy.sold? %>
                    <div class="toy-card-sold-badge">
                      <i class="fa-solid fa-tag"></i> Vendu
                    </div>
                  <% end %>
                </div>
                <div class="toy-card-body">
                  <div class="toy-card-title"><i class="fa-solid fa-gift me-1"></i>J<%= toy.id %></div>
                  <div class="toy-card-meta">
                    <span class="toy-card-category"><i class="fa-solid <%= toy.category.icon.presence || 'fa-tag' %> me-1"></i><%= truncate(toy.category.name, length: 14) %></span>
                    <div class="toy-card-conditions">
                      <span class="condition-icon <%= toy.french? ? 'ok' : 'ko' %>" title="<%= toy.french? ? 'Français' : 'Pas en français' %>">
                        <i class="fa-solid fa-flag"></i>
                      </span>
                      <span class="condition-icon <%= toy.ce_mark? ? 'ok' : 'ko' %>" title="<%= toy.ce_mark? ? 'CE / Marque connue' : 'Sans CE ni marque' %>">
                        <i class="fa-solid fa-award"></i>
                      </span>
                      <span class="condition-icon <%= toy.safe? ? 'ok' : 'ko' %>" title="<%= toy.safe? ? 'Sécurité OK' : 'Sécurité non vérifiée' %>">
                        <i class="fa-solid fa-lock"></i>
                      </span>
                      <span class="condition-icon <%= toy.complete? ? 'ok' : 'ko' %>" title="<%= toy.complete? ? 'Complet' : 'Incomplet' %>">
                        <i class="fa-solid fa-list-check"></i>
                      </span>
                      <span class="condition-icon <%= toy.playable? ? 'ok' : 'ko' %>" title="<%= toy.playable? ? 'Jouable' : 'Non jouable' %>">
                        <i class="fa-solid fa-gamepad"></i>
                      </span>
                      <span class="condition-icon <%= toy.clean? ? 'ok' : 'ko' %>" title="<%= toy.clean? ? 'Propre' : 'Pas propre' %>">
                        <i class="fa-solid fa-soap"></i>
                      </span>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Polling prix IA ── %>
  <% if @box.toys.any? { |t| t.photo.attached? && t.price.nil? } %>
    <script>
      var key = "box_reload_<%= @box.id %>";
      var count = parseInt(sessionStorage.getItem(key) || "0");
      if (count < 5) {
        sessionStorage.setItem(key, count + 1);
        setTimeout(function() { location.reload(); }, 2000);
      }
    </script>
  <% end %>

  <%# ── Modal Quick Discard ── %>
  <% unless current_user.admin? %>
    <div class="modal fade" id="quickDiscardModal" tabindex="-1" aria-labelledby="quickDiscardModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:1rem; overflow:hidden;">
          <div class="modal-header" style="background:#1A2B4A; border:none; padding:1rem 1.25rem;">
            <h5 class="modal-title" id="quickDiscardModalLabel" style="color:#fff; font-weight:700; font-size:1rem;">
              <i class="fa-solid fa-trash me-2" style="color:#E63946;"></i>Jeter un jouet directement
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
          </div>
          <%= form_with url: quick_discard_box_toys_path(@box), method: :post, scope: :toy do |f| %>
            <div class="modal-body" style="padding:1.25rem;">
              <p style="font-size:0.8rem; color:#6B7280; margin-bottom:1rem;">
                Cochez les critères <strong>respectés</strong> — laissez décochés ceux qui sont <strong style="color:#E63946;">refusés</strong>.
              </p>
              <div class="verify-conditions">
                <%= f.check_box :french,   class: "condition-toggle-input", id: "qd_french" %>
                <%= f.label :french,   class: "condition-toggle-label", for: "qd_french"   do %><i class="fa-solid fa-flag"></i><span>Français</span><% end %>

                <%= f.check_box :ce_mark,  class: "condition-toggle-input", id: "qd_ce_mark" %>
                <%= f.label :ce_mark,  class: "condition-toggle-label", for: "qd_ce_mark"  do %><i class="fa-solid fa-award"></i><span>CE / Marque</span><% end %>

                <%= f.check_box :safe,     class: "condition-toggle-input", id: "qd_safe" %>
                <%= f.label :safe,     class: "condition-toggle-label", for: "qd_safe"     do %><i class="fa-solid fa-lock"></i><span>Sécurité</span><% end %>

                <%= f.check_box :complete, class: "condition-toggle-input", id: "qd_complete" %>
                <%= f.label :complete, class: "condition-toggle-label", for: "qd_complete" do %><i class="fa-solid fa-list-check"></i><span>Complet</span><% end %>

                <%= f.check_box :playable, class: "condition-toggle-input", id: "qd_playable" %>
                <%= f.label :playable, class: "condition-toggle-label", for: "qd_playable" do %><i class="fa-solid fa-gamepad"></i><span>Jouable</span><% end %>

                <%= f.check_box :clean,    class: "condition-toggle-input", id: "qd_clean" %>
                <%= f.label :clean,    class: "condition-toggle-label", for: "qd_clean"    do %><i class="fa-solid fa-soap"></i><span>Propre</span><% end %>
              </div>

              <div class="vocal-section mt-3" data-controller="voice-recorder">
                <div class="vocal-header">
                  <span class="vocal-label">
                    <i class="fa-solid fa-microphone me-1" style="color:#FF6B35;"></i>Note vocale
                  </span>
                  <div class="vocal-controls">
                    <button type="button" class="vocal-btn vocal-btn-record"
                            data-voice-recorder-target="button"
                            data-action="click->voice-recorder#toggle"
                            title="Enregistrer">
                      <i class="fa-solid fa-microphone" data-voice-recorder-target="icon"></i>
                    </button>
                    <button type="button" class="vocal-btn vocal-btn-clear"
                            data-action="click->voice-recorder#clear"
                            title="Effacer">
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                  </div>
                </div>
                <span class="vocal-status" data-voice-recorder-target="status"></span>
                <%= f.text_area :operator_note,
                    placeholder: "Appuyez sur le micro pour dicter, ou écrivez directement…",
                    class: "form-control verify-input vocal-textarea mt-1",
                    rows: 3,
                    data: { "voice-recorder-target": "textarea" } %>
              </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid rgba(0,0,0,0.08); padding:0.75rem 1.25rem; gap:0.5rem;">
              <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
              <button type="submit" class="btn btn-sm" style="background:rgba(230,57,70,0.12); color:#E63946; font-weight:700; border:1.5px solid rgba(230,57,70,0.25);">
                <i class="fa-solid fa-trash me-1"></i>Confirmer le rejet
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Timeline ── %>
  <% if @timeline.any? %>
    <div class="row mt-4">
      <div class="col-12">
        <div class="toy-show-timeline-wrap">
          <div class="toy-show-timeline-header">
            <i class="fa-solid fa-clock-rotate-left me-2"></i>Historique
          </div>
          <div class="toy-show-timeline-scroll">
            <div class="toy-show-timeline">
              <% @timeline.each do |action| %>
                <div class="toy-show-timeline-item">
                  <div class="toy-show-timeline-dot"></div>
                  <div class="toy-show-timeline-content">
                    <span class="toy-show-timeline-date">
                      <%= action.created_at.in_time_zone('Europe/Paris').strftime('%d/%m/%Y à %H:%M') %>
                    </span>
                    <span class="toy-show-timeline-text"><%= action.content %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
