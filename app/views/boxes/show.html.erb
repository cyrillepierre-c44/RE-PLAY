<% content_for :title, "Boîte N°#{@box.id} · RE-PLAY" %>

<div class="container py-4">
  <%= link_to boxes_path, class: "btn-back-boxes mb-3 d-inline-block" do %>
    <span style="color:#000;">←</span> <i class="fa-solid fa-boxes-stacked"></i>
  <% end %>

  <div class="row g-4">
    <%# ── Colonne info boîte ── %>
    <div class="col-12 col-md-4 col-lg-3">
      <div class="detail-card p-4">

        <div class="d-flex align-items-center justify-content-between mb-3">
          <h1 class="toy-show-title">
            <% if @box.suppr? %>
              <i class="fa-solid fa-dumpster me-2"></i>
            <% elsif @box.empty? %>
              <i class="fa-solid fa-box-open me-2"></i>
            <% else %>
              <i class="fa-solid fa-box me-2"></i>
            <% end %>
            N°&nbsp;<%= @box.id %>
          </h1>
          <% if @box.suppr? %>
            <span class="status-dot status-dot-deleted" title="Jetée"></span>
          <% elsif @box.empty? %>
            <span class="status-dot status-dot-empty" title="Vide"></span>
          <% else %>
            <span class="status-dot status-dot-box-active" title="En cours"></span>
          <% end %>
        </div>

        <div class="d-flex align-items-start justify-content-between mb-3 gap-3">
          <div class="toy-show-info-grid">
            <div class="toy-show-info-item">
              <i class="fa-solid fa-tag"></i>
              <span><%= truncate(@box.category.name, length: 20) %></span>
            </div>
            <% if @box.weight.present? %>
              <div class="toy-show-info-item">
                <i class="fa-solid fa-weight-hanging"></i>
                <span><%= @box.weight %> kg</span>
              </div>
            <% end %>
            <div class="toy-show-info-item">
              <span class="condition-icon <%= @box.electronic? ? 'ok' : 'ko' %>" style="width:28px;height:28px;font-size:0.8rem;">
                <i class="fa-solid fa-bolt"></i>
              </span>
              <span><%= @box.electronic? ? 'Électronique' : 'Non électronique' %></span>
            </div>
          </div>

          <% if policy(@box).toggle_empty? && !@box.suppr? %>
            <%= button_to toggle_empty_box_path(@box), method: :patch, class: "box-toggle-btn" do %>
              <div class="box-toggle-wrap <%= @box.empty? ? 'is-empty' : 'is-full' %>">
                <div class="box-toggle-icons">
                  <i class="fa-solid fa-box icon-full" title="Pleine"></i>
                  <i class="fa-solid fa-box-open icon-empty" title="Vide"></i>
                </div>
                <div class="box-toggle-track">
                  <div class="box-toggle-thumb"></div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# Boutons action %>
        <div class="toy-show-actions">
          <% if @box.pending? %>
            <%= link_to new_box_toy_path(@box), class: "toy-show-btn toy-show-btn-verify", title: "Ajouter un jouet" do %>
              <i class="fa-solid fa-plus"></i>
            <% end %>
          <% end %>
          <% if policy(@box).edit? %>
            <%= link_to edit_box_path(@box), class: "toy-show-btn toy-show-btn-edit", title: "Modifier" do %>
              <i class="fa-solid fa-pen"></i>
            <% end %>
          <% end %>
          <% if policy(@box).destroy? && !@box.suppr? %>
            <%= link_to box_path(@box),
                  class: "toy-show-btn toy-show-btn-delete",
                  title: "Supprimer",
                  data: { turbo_method: :delete, turbo_confirm: "Supprimer cette boîte ?" } do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          <% end %>
        </div>

      </div>
    </div>

    <%# ── Colonne jouets ── %>
    <div class="col-12 col-md-8 col-lg-9">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="toy-show-title" style="font-size:1.4rem;">
          <i class="fa-solid fa-puzzle-piece me-2"></i><%= @box.toys.count %> jouet<%= 's' if @box.toys.count > 1 %>
        </h2>
      </div>

      <% if @box.toys.empty? %>
        <div class="detail-card p-4 text-center" style="color:#9CA3AF;">
          <i class="fa-solid fa-puzzle-piece" style="font-size:2.5rem; color:rgba(255,107,53,0.2); margin-bottom:0.75rem; display:block;"></i>
          Aucun jouet dans cette boîte.
          <% if @box.pending? %>
            <%= link_to new_box_toy_path(@box), class: "btn btn-primary btn-sm d-block mt-3 mx-auto", style:"width:fit-content;" do %>
              <i class="fa-solid fa-plus me-1"></i>Ajouter
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="row g-3">
          <% @box.toys.each do |toy| %>
            <div class="col-12 col-sm-6 col-xl-4">
              <div class="toy-card">
                <div class="toy-card-photo-wrap">
                  <% if toy.photo.attached? %>
                    <%= image_tag toy.photo, class: "toy-card-img" %>
                  <% else %>
                    <div class="toy-card-no-img"><i class="fa-solid fa-image"></i></div>
                  <% end %>
                  <% if toy.price.present? %>
                    <div class="toy-card-price-badge"><%= toy.price.to_i %> €</div>
                  <% end %>
                  <% if toy.suppr? %>
                    <span class="status-dot status-dot-deleted toy-card-status-dot" title="Jeté"></span>
                  <% elsif toy.market? %>
                    <span class="status-dot status-dot-validated toy-card-status-dot" title="Validé"></span>
                  <% else %>
                    <span class="status-dot status-dot-waiting toy-card-status-dot" title="En attente"></span>
                  <% end %>
                  <div class="toy-card-actions">
                    <%= link_to toy_path(toy), class: "toy-action-btn toy-action-primary", title: "Voir" do %>
                      <i class="fa-solid fa-eye"></i>
                    <% end %>
                  </div>
                </div>
                <div class="toy-card-body">
                  <div class="toy-card-title"><i class="fa-solid fa-puzzle-piece me-1"></i>N°&nbsp;<%= toy.id %></div>
                  <div class="toy-card-meta">
                    <span class="toy-card-category"><i class="fa-solid fa-tag me-1"></i><%= truncate(toy.category.name, length: 14) %></span>
                    <div class="toy-card-conditions">
                      <span class="condition-icon <%= toy.clean? ? 'ok' : 'ko' %>" title="<%= toy.clean? ? 'Propre' : 'Pas propre' %>">
                        <i class="fa-solid fa-soap"></i>
                      </span>
                      <span class="condition-icon <%= toy.complete? ? 'ok' : 'ko' %>" title="<%= toy.complete? ? 'Complet' : 'Incomplet' %>">
                        <i class="fa-solid fa-list-check"></i>
                      </span>
                      <span class="condition-icon <%= toy.playable? ? 'ok' : 'ko' %>" title="<%= toy.playable? ? 'Jouable' : 'Non jouable' %>">
                        <i class="fa-solid fa-gamepad"></i>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Polling prix IA ── %>
  <% if @box.toys.any? { |t| t.photo.attached? && t.price.nil? } %>
    <script>
      setTimeout(function() { location.reload(); }, 2000);
    </script>
  <% end %>

  <%# ── Timeline ── %>
  <% if @timeline.any? %>
    <div class="row mt-4">
      <div class="col-12">
        <div class="toy-show-timeline-wrap">
          <div class="toy-show-timeline-header">
            <i class="fa-solid fa-clock-rotate-left me-2"></i>Historique
          </div>
          <div class="toy-show-timeline-scroll">
            <div class="toy-show-timeline">
              <% @timeline.each do |action| %>
                <div class="toy-show-timeline-item">
                  <div class="toy-show-timeline-dot"></div>
                  <div class="toy-show-timeline-content">
                    <span class="toy-show-timeline-date">
                      <%= action.created_at.in_time_zone('Europe/Paris').strftime('%d/%m/%Y à %H:%M') %>
                    </span>
                    <span class="toy-show-timeline-text"><%= action.content %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
