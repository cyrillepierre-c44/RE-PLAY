<% content_for :title, "Marc Thomas · RE-PLAY" %>

<div class="container py-4">

  <%= link_to onboarding_path, class: "btn-back-boxes mb-3 d-inline-block" do %>
    <span style="color:#000;">←</span> Guide
  <% end %>

  <%# ── En-tête profil ── %>
  <div class="detail-card p-4 text-center mb-4">
    <%= image_tag "marc", alt: "Marc Thomas", class: "onb-avatar onb-avatar-lg mb-3" %>
    <h1 class="toy-show-title mb-1">Marc Thomas</h1>
    <div class="onb-team-role mb-2">Développeur</div>
    <p class="onb-tagline">Développeur Web Full-Stack junior · Business &amp; Tech</p>
  </div>

  <%# ── Bio ── %>
  <div class="detail-card p-4 mb-4 onb-bio-card">
    <p class="onb-bio-text mb-0">
      Après plusieurs années en conseil en financement de projets innovants, Marc souhaitait passer de
      l'accompagnement des solutions à leur création directe, fort d'un Master en Management de l'Innovation.
      La formation full-stack du Wagon lui a fourni les outils techniques : Ruby on Rails, JavaScript,
      PostgreSQL et IA. Son double profil business-tech a été un atout clé dans la conception de RE-Play.
    </p>
  </div>

  <%# ── Expériences ── %>
  <div class="onb-section-title">
    <span class="onb-section-bar"></span>
    <h2><i class="fa-solid fa-briefcase me-2" style="font-size:1rem;"></i>Expériences récentes</h2>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
      <div class="detail-card p-4 h-100">
        <div class="onb-exp-icon onb-icon-coral mb-2"><i class="fa-solid fa-chart-line"></i></div>
        <div class="onb-exp-date">mars 2022 – sept. 2025</div>
        <h5 class="onb-card-title">Consultant en financement de projet</h5>
        <p class="onb-exp-company">EPSA · CDI · Lyon</p>
        <p class="onb-card-text mb-0">Accompagnement stratégique et financement de projets innovants auprès d'entreprises.</p>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="detail-card p-4 h-100">
        <div class="onb-exp-icon onb-icon-sky mb-2"><i class="fa-solid fa-headset"></i></div>
        <div class="onb-exp-date">oct. – déc. 2021</div>
        <h5 class="onb-card-title">Customer Success Manager</h5>
        <p class="onb-exp-company">Agicap · Lyon</p>
        <p class="onb-card-text mb-0">Accompagnement des clients dans l'adoption d'une solution SaaS de gestion de trésorerie.</p>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="detail-card p-4 h-100">
        <div class="onb-exp-icon onb-icon-mint mb-2"><i class="fa-solid fa-code"></i></div>
        <div class="onb-exp-date">janv. – mars 2026</div>
        <h5 class="onb-card-title">Concepteur &amp; Développeur web &amp; IA</h5>
        <p class="onb-exp-company">Le Wagon · Bootcamp full-stack · RNCP niv. 6</p>
        <p class="onb-card-text mb-0">Formation intensive : Ruby on Rails, JavaScript, PostgreSQL, Git et IA. Projet final : RE-Play pour ENJOUÉ.</p>
      </div>
    </div>
  </div>

  <%# ── Compétences ── %>
  <div class="onb-section-title">
    <span class="onb-section-bar"></span>
    <h2><i class="fa-solid fa-star me-2" style="font-size:1rem;"></i>Compétences</h2>
  </div>
  <div class="detail-card p-4 mb-4">
    <div class="d-flex flex-wrap gap-2">
      <span class="onb-skill-tag"><i class="fa-solid fa-gem"></i> Ruby on Rails</span>
      <span class="onb-skill-tag"><i class="fa-brands fa-js"></i> JavaScript</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-code"></i> HTML / CSS</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-database"></i> PostgreSQL</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-plug"></i> APIs REST</span>
      <span class="onb-skill-tag"><i class="fa-brands fa-github"></i> Git / GitHub</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-arrows-spin"></i> Agile</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-robot"></i> IA</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-list-check"></i> Gestion de projet</span>
      <span class="onb-skill-tag"><i class="fa-solid fa-lightbulb"></i> Financement de l'innovation</span>
    </div>
  </div>

  <%# ── Formation & Engagements ── %>
  <div class="onb-section-title">
    <span class="onb-section-bar"></span>
    <h2><i class="fa-solid fa-graduation-cap me-2" style="font-size:1rem;"></i>Diplômes &amp; engagements</h2>
  </div>
  <div class="row g-3 mb-2">
    <div class="col-12 col-md-6">
      <div class="detail-card p-4 h-100">
        <div class="onb-sub-section-title"><i class="fa-solid fa-graduation-cap me-2"></i>Formation</div>
        <p class="onb-card-title mb-0">Le Wagon</p>
        <p class="onb-exp-company mb-3">Concepteur &amp; Développeur d'apps web · RNCP niv. 6 · 2026</p>
        <p class="onb-card-title mb-0">Université Lumière Lyon 2</p>
        <p class="onb-exp-company mb-0">Master MIPI — Management de l'Innovation &amp; PI · 2019–2021</p>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="detail-card p-4 h-100">
        <div class="onb-sub-section-title"><i class="fa-solid fa-heart me-2"></i>Engagements</div>
        <p class="onb-card-title mb-0">ZUPdeCO</p>
        <p class="onb-exp-company mb-3">Bénévole · 10 ans · Services sociaux</p>
        <p class="onb-card-title mb-0">EPA Bretagne</p>
        <p class="onb-exp-company mb-0">Étudiant startupeur · 8 ans · Autonomisation économique</p>
      </div>
    </div>
  </div>

</div>
