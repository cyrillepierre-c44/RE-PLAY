<%# ── HERO ──────────────────────────────────────────────────────────── %>
<div class="onboarding-hero">
  <div class="container py-5 text-center text-white">
    <span class="badge onboarding-badge mb-3 px-3 py-2 fs-6">RE-PLAY × ENJOUÉ</span>
    <h1 class="display-4 fw-bold mb-3" style="font-family: var(--bs-heading-font-family, inherit);">Bienvenue sur RE-PLAY</h1>
    <p class="lead mb-4 onboarding-hero-sub">
      La plateforme de gestion des jouets reconditionnés par ENJOUÉ
    </p>
    <%= link_to enjoue_path, class: "btn onboarding-cta btn-lg" do %>
      <i class="fa-solid fa-arrow-right me-2"></i>Découvrir Enjoué
    <% end %>
  </div>
</div>

<%# ── INTRO ────────────────────────────────────────────────────────── %>
<div class="container my-5">
  <div class="onboarding-intro-card p-4 p-md-5">
    <p class="fs-5 lh-lg mb-0">
      <i class="fa-solid fa-leaf me-2" style="color: #0CC9A3;"></i>
      ENJOUÉ donne une seconde vie aux jouets pour rendre le jeu plus responsable et accessible à tous.
      En choisissant des jouets reconditionnés, particuliers, professionnels de l'enfance et entreprises
      réduisent la surproduction, limitent la pollution et soutiennent l'emploi durable.
      Les jouets proposés sont rigoureusement contrôlés pour répondre aux besoins des structures les plus exigeantes.
    </p>
  </div>
</div>

<%# ── NOTRE MISSION ────────────────────────────────────────────────── %>
<section class="py-5">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-4">
      <span class="onboarding-section-bar"></span>
      <h2 class="mb-0">Notre mission</h2>
    </div>
    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-0 h-100 onboarding-step-card p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="onboarding-step-number flex-shrink-0">1</div>
            <div class="onboarding-step-icon"><i class="fa-solid fa-qrcode"></i></div>
          </div>
          <h5 class="fw-bold mb-2">Traçabilité digitale</h5>
          <p class="text-muted mb-0">
            RE‑PLAY remplace les tableurs par une traçabilité 100&nbsp;% digitale qui centralise automatiquement
            chaque jouet dans un stock fiable et toujours à jour. L'identification par photo rend l'enregistrement
            simple, rapide et sans erreur.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 h-100 onboarding-step-card p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="onboarding-step-number flex-shrink-0">2</div>
            <div class="onboarding-step-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
          </div>
          <h5 class="fw-bold mb-2">Contrôle qualité</h5>
          <p class="text-muted mb-0">
            Chaque jouet est évalué selon son état (propreté, complétude, fonctionnalité) avant d'être
            validé et remis en circulation.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 h-100 onboarding-step-card p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="onboarding-step-number flex-shrink-0">3</div>
            <div class="onboarding-step-icon"><i class="fa-solid fa-robot"></i></div>
          </div>
          <h5 class="fw-bold mb-2">Prix assisté par IA</h5>
          <p class="text-muted mb-0">
            L'intelligence artificielle analyse chaque jouet et propose automatiquement un prix de revente
            cohérent avec le marché.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ── NOTRE ÉQUIPE ─────────────────────────────────────────────────── %>
<section class="py-5">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-4">
      <span class="onboarding-section-bar"></span>
      <h2 class="mb-0">Notre équipe</h2>
    </div>

    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-0 text-center onboarding-team-card p-4">
          <%= image_tag "cyrille", alt: "Cyrille Pierre", class: "onboarding-avatar mb-3" %>
          <h5 class="fw-bold mb-1">Cyrille Pierre</h5>
          <span class="onboarding-role-badge mb-3 d-inline-block">Développeur Web Full-Stack IA</span>
          <div class="mt-3">
            <%= link_to cyrille_pierre_path, class: "onboarding-team-btn" do %>
              <i class="fa-solid fa-user"></i>Voir la présentation
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 text-center onboarding-team-card p-4">
          <%= image_tag "marc", alt: "Marc Thomas", class: "onboarding-avatar mb-3" %>
          <h5 class="fw-bold mb-1">Marc Thomas</h5>
          <span class="onboarding-role-badge mb-3 d-inline-block">Développeur Web Full-Stack IA</span>
          <div class="mt-3">
            <%= link_to marc_thomas_path, class: "onboarding-team-btn" do %>
              <i class="fa-solid fa-user"></i>Voir la présentation
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 text-center onboarding-team-card p-4">
          <%= image_tag "loic", alt: "Loïc Laplagne", class: "onboarding-avatar mb-3" %>
          <h5 class="fw-bold mb-1">Loïc Laplagne</h5>
          <span class="onboarding-role-badge mb-3 d-inline-block">Développeur Web Full-Stack IA</span>
          <div class="mt-3">
            <%= link_to loic_laplagne_path, class: "onboarding-team-btn" do %>
              <i class="fa-solid fa-user"></i>Voir la présentation
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
