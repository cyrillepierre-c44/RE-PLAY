<%# ── HERO ──────────────────────────────────────────────────────────── %>
<div class="onboarding-hero">
  <div class="container py-5 text-center text-white">
    <span class="badge onboarding-badge mb-3 px-3 py-2 fs-6">RE-PLAY × ENJOUÉ</span>
    <h1 class="display-4 fw-bold mb-3">Bienvenue sur RE-PLAY</h1>
    <p class="lead mb-4 onboarding-hero-sub">
      La plateforme de gestion des jouets reconditionnés par ENJOUÉ
    </p>
    <%= link_to "Découvrir Enjoué", enjoue_path, class: "btn onboarding-cta btn-lg fw-bold" %>
  </div>
</div>

<%# ── INTRO ────────────────────────────────────────────────────────── %>
<div class="container my-5">
  <div class="card border-0 shadow-sm onboarding-intro-card p-4 p-md-5">
    <p class="fs-5 lh-lg mb-0">
      ENJOUÉ donne une seconde vie aux jouets pour rendre le jeu plus responsable et accessible à tous.
      En choisissant des jouets reconditionnés, particuliers, professionnels de l'enfance et entreprises
      réduisent la surproduction, limitent la pollution et soutiennent l'emploi durable.
      Les jouets proposés sont rigoureusement contrôlés pour répondre aux besoins des structures les plus exigeantes.
    </p>
  </div>
</div>

<%# ── NOTRE MISSION ────────────────────────────────────────────────── %>
<section class="bg-white py-5">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-4">
      <span class="onboarding-section-bar"></span>
      <h2 class="mb-0 fw-bold">Notre mission</h2>
    </div>
    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 onboarding-step-card p-4">
          <div class="onboarding-step-number mb-3">1</div>
          <h5 class="fw-bold mb-2">Traçabilité digitale</h5>
          <p class="text-muted mb-0">
            Fini les tableurs Excel et la saisie papier. RE-PLAY centralise les stocks et suit chaque jouet
            par scan de code-barres.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 onboarding-step-card p-4">
          <div class="onboarding-step-number mb-3">2</div>
          <h5 class="fw-bold mb-2">Contrôle qualité</h5>
          <p class="text-muted mb-0">
            Chaque jouet est évalué selon son état (propreté, complétude, fonctionnalité) avant d'être
            validé et remis en circulation.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 onboarding-step-card p-4">
          <div class="onboarding-step-number mb-3">3</div>
          <h5 class="fw-bold mb-2">Prix assisté par IA</h5>
          <p class="text-muted mb-0">
            L'intelligence artificielle analyse chaque jouet et propose automatiquement un prix de revente
            cohérent avec le marché.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ── NOTRE ÉQUIPE ─────────────────────────────────────────────────── %>
<section class="py-5">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-4">
      <span class="onboarding-section-bar"></span>
      <h2 class="mb-0 fw-bold">Notre équipe</h2>
    </div>
    <p class="text-muted mb-4 fs-5">
      Derrière RE-PLAY, une équipe passionnée de développeurs, designers et experts métier.
    </p>

    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center onboarding-team-card p-4">
          <%= image_tag "cyrille", alt: "Cyrille Pierre", class: "onboarding-avatar mb-3" %>
          <h5 class="fw-bold mb-1">Cyrille Pierre</h5>
          <span class="badge onboarding-role-badge mb-3">Développeur</span>
          <div>
            <%= link_to "Voir la présentation", cyrille_pierre_path, class: "btn onboarding-team-btn btn-sm fw-bold" %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center onboarding-team-card p-4">
          <%= image_tag "marc", alt: "Marc Thomas", class: "onboarding-avatar mb-3" %>
          <h5 class="fw-bold mb-1">Marc Thomas</h5>
          <span class="badge onboarding-role-badge mb-3">Développeur</span>
          <div>
            <%= link_to "Voir la présentation", marc_thomas_path, class: "btn onboarding-team-btn btn-sm fw-bold" %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center onboarding-team-card p-4">
          <%= image_tag "loic", alt: "Loïc Laplagne", class: "onboarding-avatar mb-3" %>
          <h5 class="fw-bold mb-1">Loïc Laplagne</h5>
          <span class="badge onboarding-role-badge mb-3">Développeur</span>
          <div>
            <%= link_to "Voir la présentation", loic_laplagne_path, class: "btn onboarding-team-btn btn-sm fw-bold" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
