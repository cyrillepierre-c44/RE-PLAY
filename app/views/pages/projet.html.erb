<script>
;(function () {
  'use strict';

  var DESIGN_W = 794; // 210mm @ 96 dpi

  // ── Scaling mobile ──
  function scalePages() {
    if (window.matchMedia('print').matches) return;
    var vw = window.innerWidth;
    var pages = document.querySelectorAll('.devis-page');
    if (vw < 830) {
      var scale = (vw - 8) / DESIGN_W;
      var marginLeft = (vw / 2) - (DESIGN_W / 2);
      pages.forEach(function (p) {
        var h = p.offsetHeight;
        p.style.transform = 'scale(' + scale + ')';
        p.style.transformOrigin = 'top center';
        p.style.marginLeft = marginLeft + 'px';
        p.style.marginBottom = (h * (scale - 1) + 6) + 'px';
      });
    } else {
      pages.forEach(function (p) {
        p.style.transform = '';
        p.style.transformOrigin = '';
        p.style.marginLeft = '';
        p.style.marginBottom = '';
      });
    }
  }

  function resetScale() {
    document.querySelectorAll('.devis-page').forEach(function (p) {
      p.style.transform = '';
      p.style.transformOrigin = '';
      p.style.marginLeft = '';
      p.style.marginBottom = '';
    });
  }

  window.addEventListener('beforeprint', resetScale);
  window.addEventListener('afterprint', scalePages);
  window.addEventListener('resize', scalePages);
  scalePages();

  // ── Mode papier ──
  var btnPapier = document.getElementById('btn-papier');
  var paperMode = new URLSearchParams(location.search).get('mode') === 'papier';

  function setPaperMode(active) {
    paperMode = active;
    document.body.classList.toggle('paper-mode', active);
    if (!btnPapier) return;
    if (active) {
      btnPapier.textContent = '🎨 Version couleur';
      btnPapier.classList.add('active');
    } else {
      btnPapier.textContent = '🖨 Version papier';
      btnPapier.classList.remove('active');
    }
  }

  setPaperMode(paperMode);
  if (btnPapier) {
    btnPapier.addEventListener('click', function () { setPaperMode(!paperMode); });
  }

  // ── Impression ──
  var btnPrint = document.getElementById('btn-print');
  if (btnPrint) {
    btnPrint.addEventListener('click', function () { window.print(); });
  }

  // ── Partager ──
  var btnShare = document.getElementById('btn-share');
  if (btnShare) {
    btnShare.addEventListener('click', async function () {
      var url = new URL(location.href);
      if (paperMode) {
        url.searchParams.set('mode', 'papier');
      } else {
        url.searchParams.delete('mode');
      }
      var shareUrl = url.toString();

      if (navigator.share) {
        try {
          await navigator.share({ title: 'Devis RE-PLAY V2 — Enjoué', url: shareUrl });
        } catch (e) { /* annulé */ }
      } else {
        try {
          await navigator.clipboard.writeText(shareUrl);
          var orig = btnShare.textContent;
          btnShare.textContent = '✓ Lien copié !';
          setTimeout(function () { btnShare.textContent = orig; }, 2000);
        } catch (e) { /* accès clipboard refusé */ }
      }
    });
  }
})();
</script>
