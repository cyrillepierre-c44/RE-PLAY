<% content_for :title, "Tableau de bord · RE-PLAY" %>

<div class="container py-4">

  <%# ── Titre ── %>
  <div class="onb-section-title" style="justify-content:flex-start;" mb-4">
    <h1 style="font-size:2rem;">Tableau de bord</h1>
  </div>

  <%# ── Filtres ── %>
  <%= form_with url: dashboard_path, method: :get, local: true,
        class: "detail-card p-4 mb-4",
        data: { controller: "date-range" } do |f| %>

    <%= f.hidden_field :period, value: @period %>

    <%# Période — filter-tabs %>
    <div class="filter-tabs mb-3">
      <% [["today", "fa-calendar-day", "Aujourd'hui"], ["prev_day", "fa-clock-rotate-left", "Hier"], ["last_week", "fa-calendar-week", "Semaine"], ["custom", "fa-calendar-plus", "Dates"]].each do |val, icon, label| %>
        <button type="button"
                class="filter-tab filter-tab-period <%= 'active' if @period == val %>"
                data-period="<%= val %>"
                data-date-range-target="periodBtn"
                data-action="click->date-range#select">
          <i class="fa-solid <%= icon %>"></i>
          <span><%= label %></span>
        </button>
      <% end %>
    </div>

    <%# Panneau dates libres %>
    <div data-date-range-target="customPanel"
         class="custom-date-panel mb-3 <%= 'd-none' unless @period == 'custom' %>">
      <div class="d-flex gap-3 flex-wrap">
        <div>
          <label class="filter-label">Du</label>
          <%= f.date_field :start_date, value: @start_date, class: "form-control form-control-sm date-input",
                data: { action: "change->date-range#dateChange" } %>
        </div>
        <div>
          <label class="filter-label">Au</label>
          <%= f.date_field :end_date, value: @end_date, class: "form-control form-control-sm date-input",
                data: { action: "change->date-range#dateChange" } %>
        </div>
      </div>
    </div>

    <%# Filtres secondaires — type / catégorie / utilisateur %>
    <div id="filtres-secondaires" class="d-flex flex-column gap-2 mb-3">
      <div class="d-flex gap-2">
        <div class="flex-fill">
          <label class="filter-label"><i class="fa-solid fa-filter me-1"></i>Type</label>
          <%= f.select :type,
            [["Tous", ""], ["Jouets", "toys"], ["Boîtes", "boxes"]],
            { selected: @type_filter.to_s },
            class: "form-select form-select-sm filter-select w-100",
            data: { action: "change->date-range#autoSubmit" } %>
        </div>
        <div class="flex-fill">
          <label class="filter-label"><i class="fa-regular fa-user me-1"></i>Utilisateur</label>
          <%= f.select :user_id,
            [["Tous", ""]] + @users.map { |u| ["#{u.email.split('@').first}#{u.admin ? ' (admin)' : ''}", u.id] },
            { selected: @user_id.to_s },
            class: "form-select form-select-sm filter-select w-100",
            data: { action: "change->date-range#autoSubmit" } %>
        </div>
      </div>
      <div>
        <label class="filter-label"><i class="fa-solid fa-tag me-1"></i>Catégorie</label>
        <%= f.select :category_id,
          [["Toutes", ""]] + @categories.map { |c| [c.name, c.id] },
          { selected: @category_id.to_s },
          class: "form-select form-select-sm filter-select w-100",
          data: { action: "change->date-range#autoSubmit" } %>
      </div>
    </div>

  <% end %>

  <%# ── KPIs principaux ── %>
  <div id="resultats" class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-total">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-bolt"></i></div>
          <div class="kpi-value"><%= @total_actions %></div>
        </div>
        <div class="kpi-label">Actions totales</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-admin">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-shield-halved"></i></div>
          <div class="kpi-value"><%= @actions_by_admin %></div>
        </div>
        <div class="kpi-label">Actions admin</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-user">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-users"></i></div>
          <div class="kpi-value"><%= @actions_by_user %></div>
        </div>
        <div class="kpi-label">Actions utilisateurs</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-rework">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-rotate"></i></div>
          <div class="kpi-value"><%= @review_by_admin %></div>
        </div>
        <div class="kpi-label">Retouches</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-weight">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-microchip"></i></div>
          <div class="kpi-value">
            <%= number_with_precision(@boxes_weight_electronic, precision: 1, delimiter: " ") %>
            <span class="kpi-unit">kg</span>
          </div>
        </div>
        <div class="kpi-label">Poids jouets électroniques</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-weight">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-shapes"></i></div>
          <div class="kpi-value">
            <%= number_with_precision(@boxes_weight_non_electronic, precision: 1, delimiter: " ") %>
            <span class="kpi-unit">kg</span>
          </div>
        </div>
        <div class="kpi-label">Poids jouets non électroniques</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-rework">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-clock"></i></div>
          <div class="kpi-value">
            <%= number_with_precision(@toys_price_pending, precision: 0, delimiter: " ") %>
            <span class="kpi-unit">€</span>
          </div>
        </div>
        <div class="kpi-label">Valeurs des jouets en attente</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card kpi-price">
        <div class="kpi-main">
          <div class="kpi-icon"><i class="fa-solid fa-robot"></i></div>
          <div class="kpi-value">
            <%= number_with_precision(@toys_price_total, precision: 0, delimiter: " ") %>
            <span class="kpi-unit">€</span>
          </div>
        </div>
        <div class="kpi-label">Valeurs des jouets contrôlés</div>
      </div>
    </div>
  </div>

  <%# ── Répartition objets ── %>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="detail-card p-4 h-100">
        <div class="onb-section-title" style="justify-content:flex-start;" mb-3">
                <h2><i class="fa-solid fa-puzzle-piece me-2 text-coral"></i>Jouets vs Boîtes</h2>
        </div>
        <div class="split-stats">
          <div class="split-item">
            <span class="split-value text-sky"><%= @toy_actions_count %></span>
          </div>
          <div class="split-divider"></div>
          <div class="split-item">
            <span class="split-value text-coral"><%= @box_actions_count %></span>
          </div>
        </div>
        <% if @total_actions > 0 %>
          <div class="progress mt-3" style="height: 8px; border-radius: 4px;">
            <div class="progress-bar bg-sky" style="width: <%= (@toy_actions_count.to_f / @total_actions * 100).round %>%"></div>
            <div class="progress-bar bg-coral" style="width: <%= (@box_actions_count.to_f / @total_actions * 100).round %>%"></div>
          </div>
          <div class="progress-legend mt-1">
            <span><%= (@toy_actions_count.to_f / @total_actions * 100).round %>% jouets</span>
            <span><%= (@box_actions_count.to_f / @total_actions * 100).round %>% boîtes</span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="col-md-6">
      <div class="detail-card p-4 h-100">
        <div class="onb-section-title" style="justify-content:flex-start;" mb-3">
                <h2><i class="fa-solid fa-user-shield me-2 text-coral"></i>Admin vs Utilisateurs</h2>
        </div>
        <div class="split-stats">
          <div class="split-item">
            <span class="split-value text-purple"><%= @actions_by_admin %></span>
          </div>
          <div class="split-divider"></div>
          <div class="split-item">
            <span class="split-value text-mint"><%= @actions_by_user %></span>
          </div>
        </div>
        <% if @total_actions > 0 %>
          <div class="progress mt-3" style="height: 8px; border-radius: 4px;">
            <div class="progress-bar bg-purple" style="width: <%= (@actions_by_admin.to_f / @total_actions * 100).round %>%"></div>
            <div class="progress-bar bg-mint" style="width: <%= (@actions_by_user.to_f / @total_actions * 100).round %>%"></div>
          </div>
          <div class="progress-legend mt-1">
            <span><%= (@actions_by_admin.to_f / @total_actions * 100).round %>% admin</span>
            <span><%= (@actions_by_user.to_f / @total_actions * 100).round %>% utilisateurs</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Types d'actions ── %>
  <div class="detail-card p-4 mb-4">
    <div class="onb-section-title" style="justify-content:flex-start;" mb-3">
        <h2><i class="fa-solid fa-list-check me-2 text-coral"></i>Types d'actions</h2>
    </div>
    <div class="action-types-grid">
      <div class="action-type-item action-type-create">
        <i class="fa-solid fa-plus-circle"></i>
        <span class="action-type-value"><%= @create_total %></span>
        <span class="action-type-label">Créations</span>
      </div>
      <div class="action-type-item action-type-rework">
        <i class="fa-solid fa-rotate"></i>
        <span class="action-type-value"><%= @review_by_admin %></span>
        <span class="action-type-label">Retouches</span>
      </div>
      <div class="action-type-item action-type-verify">
        <i class="fa-solid fa-circle-check"></i>
        <span class="action-type-value"><%= @verify_total %></span>
        <span class="action-type-label">Validations</span>
      </div>
      <div class="action-type-item action-type-delete">
        <i class="fa-solid fa-trash"></i>
        <span class="action-type-value"><%= @delete_total %></span>
        <span class="action-type-label">Suppressions</span>
      </div>
    </div>
  </div>

  <%# ── Top 10 retouches par créateur ── %>
  <div class="detail-card p-4 mb-4">
    <div class="onb-section-title" style="justify-content:flex-start;" mb-3">
        <h2><i class="fa-solid fa-triangle-exclamation me-2 text-coral"></i>Top 10 retouches par créateur</h2>
    </div>

    <% if @rework_by_creator.empty? %>
      <div class="empty-state">
        <i class="fa-solid fa-inbox"></i>
        <p>Aucune revalorisation sur cette période.</p>
      </div>
    <% else %>
      <% max_count = @rework_by_creator.first[:count].to_f %>
      <div class="rework-chart">
        <% @rework_by_creator.each do |item| %>
          <% pct = (item[:count] / max_count * 100).round %>
          <div class="rework-chart-col">
            <div class="rework-chart-value"><%= item[:count] %></div>
            <div class="rework-chart-bar" style="height: <%= pct %>%"></div>
            <div class="rework-chart-label" title="<%= item[:user]&.email %>">
              <%= item[:user]&.email&.split('@')&.first || "?" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="rework-chart-footer mt-3">
      <span class="rework-number"><%= @review_by_admin %></span>
      <span class="rework-chart-footer-label">retouche<%= @review_by_admin > 1 ? 's' : '' %> au total sur la période</span>
    </div>
  </div>

  <%# ── Pareto des catégories ── %>
  <div class="detail-card p-4 mb-4">
    <div class="onb-section-title" style="justify-content:flex-start;" mb-3">
        <h2>
        <i class="fa-solid fa-ranking-star me-2 text-coral"></i>Catégories les plus rentables
      </h2>
    </div>

    <% if @pareto_data.empty? %>
      <div class="empty-state">
        <i class="fa-solid fa-inbox"></i>
        <p>Aucune catégorie pour cette période.</p>
      </div>
    <% else %>
      <div class="pareto-chart">
        <% @pareto_data.each_with_index do |row, index| %>
          <div class="pareto-row pareto-vital">
            <div class="pareto-rank">
              <span class="rank-badge rank-vital"><%= index + 1 %></span>
            </div>
            <div class="pareto-category">
              <span class="pareto-cat-name"><%= row[:category]&.name || "Catégorie ##{row[:category]&.id}" %></span>
              <div class="pareto-bars">
                <% w_pct = @pareto_total_weight.positive? ? (row[:weight] / @pareto_total_weight * 100).round : 0 %>
                <% p_pct = @pareto_total_price.positive?  ? (row[:price]  / @pareto_total_price  * 100).round : 0 %>
                <div class="mini-bar-row">
                  <span class="mini-bar-label"><i class="fa-solid fa-weight-hanging"></i></span>
                  <div class="mini-bar-wrap">
                    <div class="mini-bar mini-bar-weight" style="width: <%= w_pct %>%"></div>
                  </div>
                  <span class="mini-bar-value"><%= number_with_precision(row[:weight], precision: 1) %> kg · <%= w_pct %>%</span>
                </div>
                <div class="mini-bar-row">
                  <span class="mini-bar-label"><i class="fa-solid fa-robot"></i></span>
                  <div class="mini-bar-wrap">
                    <div class="mini-bar mini-bar-price" style="width: <%= p_pct %>%"></div>
                  </div>
                  <span class="mini-bar-value"><%= number_with_precision(row[:price], precision: 0) %> € · <%= p_pct %>%</span>
                </div>
              </div>
            </div>
            <div class="pareto-cumul">
              <div class="cumul-badge cumul-vital"><%= row[:cumulative] %>%</div>
              <span class="cumul-label">cumulé</span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Journal des actions ── %>
  <div class="detail-card p-4 mb-5">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-3">
      <div class="onb-section-title" style="justify-content:flex-start;">
        <h2>
          <i class="fa-solid fa-clock-rotate-left me-2 text-coral"></i>
          Journal des actions
        </h2>
      </div>
      <div class="d-none d-sm-flex justify-content-sm-end mt-sm-0">
        <%= link_to dashboard_export_csv_path(
              period: @period, type: @type_filter, category_id: @category_id,
              user_id: @user_id, start_date: @start_date, end_date: @end_date),
              class: "btn-ghost-coral btn-sm d-flex align-items-center gap-1" do %>
          <i class="fa-solid fa-arrow-down-to-line"></i>
          <span>Exporter CSV</span>
        <% end %>
      </div>
    </div>

    <% if @recent_actions.empty? %>
      <div class="empty-state">
        <i class="fa-solid fa-inbox"></i>
        <p>Aucune action sur cette période.</p>
      </div>
    <% else %>
      <div class="toy-show-timeline-scroll dash-journal-scroll dash-journal-indent">
        <div class="toy-show-timeline">
          <% @recent_actions.each do |action| %>
            <div class="toy-show-timeline-item">
              <div class="toy-show-timeline-dot"></div>
              <div class="toy-show-timeline-content">
                <span class="toy-show-timeline-date">
                  <%= action.created_at.in_time_zone('Europe/Paris').strftime('%d/%m/%Y à %H:%M') %>
                </span>
                <span class="toy-show-timeline-text"><%= action.content %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

</div>
