      <span class="badge onboarding-role-badge fs-6 px-3 py-2">Management opérationnel</span>
      <span class="badge onboarding-role-badge fs-6 px-3 py-2">Change Management</span>
      <span class="badge onboarding-role-badge fs-6 px-3 py-2">Lean Six Sigma</span>
      <span class="badge onboarding-role-badge fs-6 px-3 py-2">Gestion de projet</span>
      <span class="badge onboarding-role-badge fs-6 px-3 py-2">Gestion budgétaire</span>
    </div>
  </div>
</section>

<%# ── BLOC 3 : Diplômes & intérêts ───────────────────────────────── %>
<section class="bg-white py-5">
  <div class="container">
    <div class="d-flex align-items-center gap-2 mb-4">
      <span class="onboarding-section-bar"></span>
      <h2 class="mb-0 fw-bold">Diplômes &amp; intérêts</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm onboarding-step-card p-4 h-100">
          <h6 class="fw-bold text-uppercase small mb-3" style="color: #E67E22; letter-spacing: .06em;">Formation</h6>
          <p class="mb-1 fw-semibold">Arts et Métiers ParisTech</p>
          <p class="text-muted small mb-3">Ingénieur généraliste &middot; Master · 2000–2003</p>
          <p class="mb-1 fw-semibold">IUT Nancy-Brabois</p>
          <p class="text-muted small mb-0">DUT Génie Mécanique et Productique &middot; mention Bien · 1998–2000</p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm onboarding-step-card p-4 h-100">
          <h6 class="fw-bold text-uppercase small mb-3" style="color: #E67E22; letter-spacing: .06em;">Engagements &amp; intérêts</h6>
          <p class="mb-1 fw-semibold">Bénévolat</p>
          <p class="text-muted small mb-3">Responsable Relations Industrie, Association Gadz'arts de Cluny</p>
          <p class="mb-1 fw-semibold">Passion</p>
          <p class="text-muted small mb-0">Électrification et reconditionnement de vélos</p>
        </div>
      </div>
    </div>
  </div>
