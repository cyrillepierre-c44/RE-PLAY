<% content_for :title, "Accueil · RE-PLAY" %>

<div class="home-hero">
  <h1 class="hero-title">Bonjour <%= current_user.email.split('@').first.capitalize %> !</h1>
  <p class="hero-subtitle">Bienvenue sur RE-PLAY — la plateforme de reconditionnement de jouets Enjoué</p>
</div>

<div class="container home-stats">
  <div class="row g-3">
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-icon stat-icon-yellow">
          <i class="fa-solid fa-clock"></i>
        </div>
        <div>
          <div class="stat-value"><%= Toy.waiting.count %></div>
          <div class="stat-label">En attente</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-icon stat-icon-mint">
          <i class="fa-solid fa-circle-check"></i>
        </div>
        <div>
          <div class="stat-value"><%= Toy.validated.count %></div>
          <div class="stat-label">Validés</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-icon stat-icon-coral">
          <i class="fa-solid fa-box"></i>
        </div>
        <div>
          <div class="stat-value"><%= Box.count %></div>
          <div class="stat-label">Boîtes</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-icon stat-icon-sky">
          <i class="fa-solid fa-puzzle-piece"></i>
        </div>
        <div>
          <div class="stat-value"><%= Toy.count %></div>
          <div class="stat-label">Total jouets</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container mt-4 mb-5">
  <h2 class="mb-3" style="font-size:1.3rem; color: #6B7280; font-family: inherit; font-weight: 700;">Actions rapides</h2>
  <div class="row g-3">
    <div class="col-6 col-md-3">
      <%= link_to boxes_path, class: "quick-action-card" do %>
        <div class="quick-action-icon icon-boxes">
          <i class="fa-solid fa-box-open"></i>
        </div>
        <span class="quick-action-label">Voir les boîtes</span>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to toys_path, class: "quick-action-card" do %>
        <div class="quick-action-icon icon-toys">
          <i class="fa-solid fa-puzzle-piece"></i>
        </div>
        <span class="quick-action-label">Voir les jouets</span>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to new_box_path, class: "quick-action-card" do %>
        <div class="quick-action-icon icon-new">
          <i class="fa-solid fa-plus"></i>
        </div>
        <span class="quick-action-label">Nouvelle boîte</span>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to toys_path(filter: "waiting"), class: "quick-action-card" do %>
        <div class="quick-action-icon icon-verify">
          <i class="fa-solid fa-magnifying-glass"></i>
        </div>
        <span class="quick-action-label">Jouets à contrôler</span>
      <% end %>
    </div>
  </div>
</div>
