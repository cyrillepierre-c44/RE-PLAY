<% if user_signed_in? %>
  <div class="auth-wrapper">
    <div class="auth-background">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>

    <div class="auth-card-modern">
      <div class="auth-illustration home-illustration">
        <div class="toy-icon">🎮</div>
        <h1>Bonjour <%= current_user.email %> !</h1>
        <p>Prêt à jouer ?</p>
      </div>

      <div class="auth-form">
        <div class="home-actions">
          <%= link_to boxes_path, class: "btn-home btn-primary" do %>
            <span class="btn-icon">📦</span>
            Mes boites
          <% end %>

          <%= link_to toys_path, class: "btn-home btn-secondary" do %>
            <span class="btn-icon">🧸</span>
            Mes jouets
          <% end %>

          <%= link_to about_us_path, class: "btn-home btn-tertiary" do %>
            <span class="btn-icon">ℹ️</span>
            À propos
          <% end %>

          <%= link_to onboarding_path, class: "btn-home btn-tertiary" do %>
            <span class="btn-icon">🚀</span>
            Onboarding
          <% end %>
        </div>

        <div class="auth-footer">
          <%= button_to "Se déconnecter", destroy_user_session_path, method: :delete, class: "logout-btn" %>
        </div>
      </div>
    </div>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

    * {
      box-sizing: border-box;
    }

    .auth-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      font-family: 'Poppins', sans-serif;
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
    }

    .auth-background {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      z-index: 0;
    }

    .shape {
      position: absolute;
      border-radius: 50%;
      opacity: 0.15;
      animation: float 6s ease-in-out infinite;
    }

    .shape-1 {
      width: 300px;
      height: 300px;
      background: #06B6D4;
      top: -100px;
      right: -100px;
      animation-delay: 0s;
    }

    .shape-2 {
      width: 200px;
      height: 200px;
      background: #3B82F6;
      bottom: -50px;
      left: -50px;
      animation-delay: 2s;
    }

    .shape-3 {
      width: 150px;
      height: 150px;
      background: #14B8A6;
      top: 50%;
      right: 10%;
      animation-delay: 4s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(5deg); }
    }

    .auth-card-modern {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 24px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
      width: 100%;
      max-width: 420px;
      z-index: 1;
      overflow: hidden;
    }

    .auth-illustration {
      background: linear-gradient(135deg, #06B6D4 0%, #0891B2 50%, #0E7490 100%);
      padding: 2.5rem 2rem 2rem;
      text-align: center;
      position: relative;
    }

    .home-illustration::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 20.5V18H0v-2h20v-2.5l5 4-5 4z' fill='%23ffffff' fill-opacity='0.1'/%3E%3C/svg%3E");
      opacity: 0.3;
    }

    .toy-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
      animation: wiggle 2s ease-in-out infinite;
      position: relative;
      z-index: 1;
    }

    @keyframes wiggle {
      0%, 100% { transform: rotate(-5deg); }
      50% { transform: rotate(5deg); }
    }

    .auth-illustration h1 {
      color: white;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      position: relative;
      z-index: 1;
    }

    .auth-illustration p {
      color: rgba(255, 255, 255, 0.9);
      font-size: 1rem;
      margin: 0;
      position: relative;
      z-index: 1;
    }

    .auth-form {
      padding: 2rem;
    }

    .home-actions {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .btn-home {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 16px;
      font-size: 1rem;
      font-weight: 600;
      border-radius: 14px;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .btn-primary {
      background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%);
      color: white;
      box-shadow: 0 4px 15px rgba(6, 182, 212, 0.35);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(6, 182, 212, 0.45);
      color: white;
    }

    .btn-secondary {
      background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
      color: white;
      box-shadow: 0 4px 15px rgba(139, 92, 246, 0.35);
    }

    .btn-secondary:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(139, 92, 246, 0.45);
      color: white;
    }

    .btn-tertiary {
      background: white;
      color: #06B6D4;
      border: 2px solid #06B6D4;
    }

    .btn-tertiary:hover {
      background: #06B6D4;
      color: white;
      transform: translateY(-2px);
    }

    .btn-icon {
      font-size: 1.3rem;
    }

    .auth-footer {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 2px dashed #eee;
      text-align: center;
    }

    .logout-btn {
      background: transparent;
      color: #666;
      border: none;
      font-size: 0.95rem;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .logout-btn:hover {
      color: #FF6B6B;
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      .auth-card-modern {
        border-radius: 20px;
      }

      .auth-illustration {
        padding: 2rem 1.5rem 1.5rem;
      }

      .auth-form {
        padding: 1.5rem;
      }

      .toy-icon {
        font-size: 3rem;
      }

      .auth-illustration h1 {
        font-size: 1.3rem;
      }
    }
  </style>
<% else %>
  <div class="auth-wrapper">
    <div class="auth-background">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>

    <div class="auth-card-modern">
      <div class="auth-illustration home-illustration">
        <div class="toy-icon">🎮</div>
        <h1>Bienvenue sur RE-PLAY !</h1>
        <p>Le site parfait pour gérer tes jouets</p>
      </div>

      <div class="auth-form">
        <div class="welcome-actions">
          <%= link_to new_user_session_path, class: "btn-home btn-primary" do %>
            <span class="btn-icon">🔑</span>
            Se connecter
          <% end %>

          <%= link_to new_user_registration_path, class: "btn-home btn-secondary" do %>
            <span class="btn-icon">🎉</span>
            Créer un compte
          <% end %>
        </div>

        <div class="divider">
          <span>ou</span>
        </div>

        <div class="guest-links">
          <%= link_to boxes_path, class: "btn-guest" do %>
            <span class="btn-icon">📦</span>
            Voir les boites
          <% end %>

          <%= link_to toys_path, class: "btn-guest" do %>
            <span class="btn-icon">🧸</span>
            Voir les jouets
          <% end %>
        </div>
      </div>
    </div>
  </div>

