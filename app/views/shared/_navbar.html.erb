<nav class="navbar navbar-expand-md navbar-replay">
  <div class="container">

    <%= link_to root_path, class: "navbar-brand" do %>
      <span class="brand-text">RE-PLAY</span>
    <% end %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarMain" aria-controls="navbarMain"
            aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <% if user_signed_in? %>
        <ul class="navbar-nav mx-auto gap-1">
          <li class="nav-item">
            <%= link_to boxes_path, class: "nav-link #{'active' if controller_name == 'boxes'}" do %>
              <i class="fa-solid fa-box"></i> Boîtes
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to toys_path, class: "nav-link #{'active' if controller_name == 'toys'}" do %>
              <i class="fa-solid fa-puzzle-piece"></i> Jouets
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to onboarding_path, class: "nav-link #{'active' if action_name == 'onboarding'}" do %>
              <i class="fa-solid fa-circle-info"></i> Guide
            <% end %>
          </li>
          <% if current_user.admin %>
            <li class="nav-item">
              <%= link_to dashboard_path, class: "nav-link #{'active' if action_name == 'dashboard'}" do %>
                <i class="fa-solid fa-chart-bar"></i> Dashboard
              <% end %>
            </li>
          <% end %>
        </ul>

        <div class="navbar-nav-right">
          <div class="dropdown">
            <a href="#" class="user-chip" id="userDropdown"
               data-bs-toggle="dropdown" aria-expanded="false">
              <div class="user-avatar">
                <%= current_user.email[0].upcase %>
              </div>
              <span class="d-none d-lg-inline"><%= current_user.email.split('@').first %></span>
              <i class="fa-solid fa-chevron-down" style="font-size:0.65rem; color: #9CA3AF;"></i>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
              <li>
                <%= link_to edit_user_registration_path, class: "dropdown-item" do %>
                  <i class="fa-regular fa-user me-2"></i>Mon profil
                <% end %>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <%= link_to destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "dropdown-item text-danger" do %>
                  <i class="fa-solid fa-right-from-bracket me-2"></i>Se déconnecter
                <% end %>
              </li>
            </ul>
          </div>
        </div>
      <% else %>
        <ul class="navbar-nav ms-auto gap-1">
          <li class="nav-item">
            <%= link_to "Se connecter", new_user_session_path, class: "btn btn-primary btn-sm" %>
          </li>
          <li class="nav-item">
            <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-ghost btn-sm" %>
          </li>
        </ul>
      <% end %>
    </div>

  </div>
</nav>
