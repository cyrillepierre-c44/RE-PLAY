<% content_for :title, "Mon profil · RE-PLAY" %>

<div class="form-page">
  <div class="container">
    <div class="form-card">
      <div class="form-card-header">
        <div class="form-card-icon" style="background: linear-gradient(135deg, rgba(76,201,240,0.15), rgba(12,201,163,0.2)); color: #0CC9A3;">
          <i class="fa-regular fa-user"></i>
        </div>
        <h1 class="form-card-title">Mon profil</h1>
        <p class="form-card-subtitle"><%= resource.email %></p>
      </div>
      <div class="form-card-body">
        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          <%= f.error_notification %>

          <div class="mb-3">
            <%= f.input :email,
              label: "Adresse e-mail",
              required: true,
              autofocus: true,
              input_html: { class: "form-control" },
              label_html: { class: "form-label" } %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="alert" style="background:rgba(76,201,240,0.1);color:#118AB2;border-radius:0.75rem;padding:0.75rem 1rem;font-size:0.875rem;">
              Confirmation en attente pour : <strong><%= resource.unconfirmed_email %></strong>
            </div>
          <% end %>

          <hr style="border-color: #F0EBE3; margin: 1.25rem 0;">
          <h3 style="font-size: 1rem; color: #6B7280; font-weight: 700; margin-bottom: 1rem;">Changer le mot de passe</h3>

          <div class="mb-3">
            <%= f.input :password,
              label: "Nouveau mot de passe",
              hint: "Laisser vide pour ne pas changer",
              required: false,
              input_html: { autocomplete: "new-password", class: "form-control", placeholder: "Laisser vide pour ne pas modifier" },
              label_html: { class: "form-label" } %>
          </div>
          <div class="mb-3">
            <%= f.input :password_confirmation,
              label: "Confirmer le nouveau mot de passe",
              required: false,
              input_html: { autocomplete: "new-password", class: "form-control" },
              label_html: { class: "form-label" } %>
          </div>
          <div class="mb-4">
            <%= f.input :current_password,
              label: "Mot de passe actuel",
              hint: "Obligatoire pour confirmer les modifications",
              required: true,
              input_html: { autocomplete: "current-password", class: "form-control" },
              label_html: { class: "form-label" } %>
          </div>

          <div class="d-grid">
            <%= f.button :submit, "Enregistrer les modifications", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>

        <hr style="border-color: #F0EBE3; margin: 1.5rem 0;">
        <div style="background: rgba(230,57,70,0.05); border-radius: 0.75rem; padding: 1rem;">
          <h3 style="font-size:0.95rem; color: #E63946; font-weight: 700; margin-bottom: 0.5rem;">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>Zone dangereuse
          </h3>
          <p style="font-size: 0.85rem; color: #6B7280; margin-bottom: 0.75rem;">
            La suppression de votre compte est irréversible.
          </p>
          <%= button_to "Supprimer mon compte",
                registration_path(resource_name),
                data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer votre compte ?" },
                method: :delete,
                class: "btn btn-sm",
                style: "background: rgba(230,57,70,0.1); color: #E63946; font-weight: 700;" %>
        </div>

        <div class="auth-links mt-3">
          <%= link_to "← Retour", :back %>
        </div>
      </div>
    </div>
  </div>
</div>
