<div class="auth-wrapper">
  <div class="auth-background">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>

  <div class="auth-card-modern">
    <div class="auth-illustration signup-illustration">
      <div class="toy-icon">🎉</div>
      <h1>Rejoins la fête !</h1>
      <p>Crée ton compte et commence à jouer</p>
    </div>

    <div class="auth-form">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
          <div class="input-wrapper">
            <span class="input-icon">✉️</span>
            <%= f.input :email,
                        required: true,
                        autofocus: true,
                        placeholder: "Ton email",
                        label: false,
                        input_html: {
                          autocomplete: "email",
                          class: "modern-input"
                        } %>
          </div>

          <div class="input-wrapper">
            <span class="input-icon">🔒</span>
            <%= f.input :password,
                        required: true,
                        placeholder: "Mot de passe",
                        label: false,
                        hint: ("#{@minimum_password_length} caractères min." if @minimum_password_length),
                        input_html: {
                          autocomplete: "new-password",
                          class: "modern-input"
                        } %>
          </div>

          <div class="input-wrapper">
            <span class="input-icon">🔐</span>
            <%= f.input :password_confirmation,
                        required: true,
                        placeholder: "Confirme ton mot de passe",
                        label: false,
                        input_html: {
                          autocomplete: "new-password",
                          class: "modern-input"
                        } %>
          </div>

          <div class="terms-wrapper">
            <span class="terms-label">En créant un compte, tu acceptes nos <a href="#" class="terms-link">conditions</a> et notre <a href="#" class="terms-link">politique de confidentialité</a></span>
          </div>
        </div>

        <div class="form-actions">
          <%= f.button :submit, "Créer mon compte ✨", class: "btn-modern btn-signup" %>
        </div>
      <% end %>

      <div class="auth-footer">
        <p>Déjà un compte ? <%= link_to "Se connecter", new_session_path(resource_name), class: "login-link" %></p>
      </div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  * {
    box-sizing: border-box;
  }

  .auth-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    font-family: 'Poppins', sans-serif;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  }

  .auth-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
    animation: float 6s ease-in-out infinite;
  }

  .shape-1 {
    width: 280px;
    height: 280px;
    background: #FF6B6B;
    top: -80px;
    right: -80px;
    animation-delay: 0s;
  }

  .shape-2 {
    width: 220px;
    height: 220px;
    background: #4ECDC4;
    bottom: -60px;
    left: -60px;
    animation-delay: 2s;
  }

  .shape-3 {
    width: 180px;
    height: 180px;
    background: #FFE66D;
    top: 40%;
    left: 5%;
    animation-delay: 4s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }

  .auth-card-modern {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    width: 100%;
    max-width: 420px;
    z-index: 1;
    overflow: hidden;
  }

  .auth-illustration {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #6B8DD6 100%);
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    position: relative;
  }

  .signup-illustration {
    background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 50%, #093028 100%);
  }

  .auth-illustration::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 20.5V18H0v-2h20v-2.5l5 4-5 4z' fill='%23ffffff' fill-opacity='0.1'/%3E%3C/svg%3E");
    opacity: 0.3;
  }

  .toy-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: wiggle 2s ease-in-out infinite;
    position: relative;
    z-index: 1;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
  }

  .auth-illustration h1 {
    color: white;
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .auth-illustration p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .auth-form {
    padding: 2rem;
  }

  .input-wrapper {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .input-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.1rem;
    z-index: 1;
  }

  .modern-input {
    width: 100%;
    padding: 14px 16px 14px 48px !important;
    border: 2px solid #E8E8E8 !important;
    border-radius: 12px !important;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #F9F9F9;
  }

  .modern-input:focus {
    border-color: #4ECDC4 !important;
    background: white !important;
    box-shadow: 0 0 0 4px rgba(78, 205, 196, 0.15) !important;
    outline: none;
  }

  .terms-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .terms-wrapper .modern-checkbox {
    margin-top: 0.2rem;
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .modern-checkbox:checked {
    background-color: #4ECDC4;
    border-color: #4ECDC4;
  }

  .terms-label {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.4;
  }

  .terms-link {
    color: #4ECDC4;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .terms-link:hover {
    color: #44A08D;
    text-decoration: underline;
  }

  .btn-modern {
    width: 100%;
    padding: 16px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 14px;
    background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
    border: none;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(78, 205, 196, 0.35);
  }

  .btn-modern:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(78, 205, 196, 0.45);
  }

  .btn-modern:active {
    transform: translateY(-1px);
  }

  .auth-footer {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px dashed #eee;
    text-align: center;
  }

  .auth-footer p {
    margin: 0;
    color: #666;
    font-size: 0.95rem;
  }

  .login-link {
    color: #4ECDC4;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .login-link:hover {
    color: #44A08D;
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .auth-card-modern {
      border-radius: 20px;
    }

    .auth-illustration {
      padding: 2rem 1.5rem 1.5rem;
    }

    .auth-form {
      padding: 1.5rem;
    }

    .toy-icon {
      font-size: 3rem;
    }

    .terms-wrapper {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
