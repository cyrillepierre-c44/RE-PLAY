<% content_for :title, "Nouveau mot de passe · RE-PLAY" %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card-header">
      <div class="auth-logo">RE-PLAY</div>
      <p class="auth-subtitle">Plateforme de reconditionnement Enjoué</p>
    </div>
    <div class="auth-card-body">
      <h2 style="font-size:1.3rem; color:#1A2B4A; margin-bottom:0.5rem;">Choisir mon mot de passe</h2>

      <% if @user_email.present? %>
        <p style="font-size:0.9rem; color:#6B7280; margin-bottom:1.25rem;">Compte : <strong><%= @user_email %></strong></p>
      <% end %>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, data: { controller: "password-toggle" } }) do |f| %>
        <%= f.error_notification %>
        <%= f.input :reset_password_token, as: :hidden %>
        <%= f.full_error :reset_password_token %>

        <div class="mb-3">
          <%= f.input :password,
            label: "Nouveau mot de passe",
            required: true,
            autofocus: true,
            hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
            input_html: { autocomplete: "new-password", class: "form-control", placeholder: "••••••••" },
            label_html: { class: "form-label" } %>
        </div>
        <div class="mb-4">
          <%= f.input :password_confirmation,
            label: "Confirmer le mot de passe",
            required: true,
            input_html: { autocomplete: "new-password", class: "form-control", placeholder: "••••••••" },
            label_html: { class: "form-label" } %>
        </div>

        <div class="d-grid">
          <%= f.button :submit, "Valider mon mot de passe", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
