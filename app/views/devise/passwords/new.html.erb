<% content_for :title, "Mot de passe oublié · RE-PLAY" %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card-header">
      <div class="auth-logo">RE-PLAY</div>
      <p class="auth-subtitle">Réinitialisation du mot de passe</p>
    </div>
    <div class="auth-card-body">
      <h2 style="font-size:1.3rem; color:#1A2B4A; margin-bottom:0.5rem;">Mot de passe oublié ?</h2>
      <p style="color:#6B7280; font-size:0.875rem; margin-bottom:1.5rem;">
        Entrez votre e-mail, nous vous enverrons un lien de réinitialisation.
      </p>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>
        <div class="mb-4">
          <%= f.input :email,
            label: "Adresse e-mail",
            required: true,
            autofocus: true,
            input_html: { autocomplete: "email", class: "form-control", placeholder: "votre@email.com" },
            label_html: { class: "form-label" } %>
        </div>
        <div class="d-grid">
          <%= f.button :submit, "Envoyer les instructions", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <div class="auth-links">
        <%= link_to "← Retour à la connexion", new_session_path(resource_name) %>
      </div>
    </div>
  </div>
</div>
