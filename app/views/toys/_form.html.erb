<div class=container >
  <div class="request-form">
    <%= simple_form_for [@box, @toy] do |f| %>

      <div class="mb-3">
        <%= f.association :category,
          label: "Catégorie du jouet",
          input_html: { class: "form-control", value: @box.category.name } %>
      </div>

      <div class="mb-3">
        <%= f.input :barcode,
          label: "Identification du jouet (facultatif)",
          input_html: { class: "form-control" } %>
      </div>

      <div class="mb-3">
        <%= f.input :photo,
          as: :file,
          label: "Photo de l'objet",
          input_html: { class: "form-control" },
          label_html: { class: "form-label" } %>
      </div>

      <div class="mb-3 form-check">
        <%= f.input :clean,
          label: "Cocher si le jouet est propre",
          input_html: { class: "form-check-input" },
          wrapper_html: { class: "form-check" } %>
      </div>

      <div class="mb-3 form-check">
        <%= f.input :complete,
          label: "Cocher si le jouet est complet",
          input_html: { class: "form-check-input" },
          wrapper_html: { class: "form-check" } %>
      </div>

      <div class="mb-3 form-check">
        <%= f.input :playable,
          label: "Cocher si le jouet est jouable",
          input_html: { class: "form-check-input" },
          wrapper_html: { class: "form-check" } %>
      </div>

      <div class="mb-3">
        <%= f.input :price,
          label: "Prix (€)",
          as: :numeric,
          input_html: { class: "form-control", step: 0.01 } %>
      </div>

      <div class="mb-3">
        <%= f.input :location,
          label: "Lieu où se trouve le jouet (facultatif)",
          as: :numeric,
          input_html: { class: "form-control", step: 0.01 } %>
      </div>

      <div class="d-grid gap-2">
        <%= f.button :submit, "Soumettre", class: "btn btn-primary btn-lg" %>
      </div>

    <% end %>
  </div>
</div>
