<%= simple_form_for @toy.persisted? ? @toy : [@box, @toy] do |f| %>
  <% if params[:new] %>
    <%= hidden_field_tag :from_new, "1" %>
  <% end %>

  <%# Zone photo %>
  <%= f.input :photo, as: :file, label: false,
      input_html: { id: "toy-photo-input", accept: "image/*", capture: "environment", style: "display:none;" } %>

  <% if @toy.photo.attached? %>
    <%# Photo existante + bouton changer %>
    <div class="d-flex align-items-center mb-2">
      <img id="photo-current" src="<%= url_for(@toy.photo) %>"
           style="height:173px; width:auto; max-width:calc(100% - 96px); object-fit:contain; border-radius:0.75rem; display:block;">
      <img id="photo-preview" src="" style="display:none; max-height:173px; width:auto; max-width:calc(100% - 96px); object-fit:contain; border-radius:0.75rem;">
      <div class="flex-grow-1 d-flex justify-content-center">
        <label for="toy-photo-input" class="verify-photo-overlay position-static" title="Changer la photo"
               style="flex-shrink:0; width:72px; height:72px; font-size:2.2rem; border-radius:0.75rem;">
          <i class="fa-solid fa-camera-rotate"></i>
        </label>
      </div>
    </div>
  <% else %>
    <%# Grande zone cliquable pour prendre / importer %>
    <label for="toy-photo-input" class="form-photo-dropzone mb-2" id="photo-dropzone">
      <div id="photo-dropzone-placeholder">
        <i class="fa-solid fa-camera" style="font-size:2.8rem; color:rgba(255,107,53,0.5); margin-bottom:0.5rem;"></i>
        <div style="font-weight:700; color:#FF6B35; font-size:1rem;">Prendre ou importer une photo</div>
        <div style="font-size:0.8rem; color:#9CA3AF; margin-top:0.2rem;">Appuyez pour ouvrir l'appareil photo</div>
      </div>
      <img id="photo-preview" src="" style="display:none; max-height:173px; width:auto; max-width:100%; object-fit:contain; border-radius:0.75rem;">
    </label>
  <% end %>

  <script>
    document.getElementById('toy-photo-input').addEventListener('change', function(e) {
      if (e.target.files && e.target.files[0]) {
        const reader = new FileReader();
        reader.onload = function(ev) {
          const preview = document.getElementById('photo-preview');
          preview.src = ev.target.result;
          preview.style.display = 'block';
          const placeholder = document.getElementById('photo-dropzone-placeholder');
          if (placeholder) placeholder.style.display = 'none';
          const current = document.getElementById('photo-current');
          if (current) current.style.display = 'none';
        };
        reader.readAsDataURL(e.target.files[0]);
      }
    });
  </script>

  <%# Catégorie %>
  <div class="mb-2">
    <%= f.association :category, label: false, prompt: "Catégorie…",
        selected: @toy.category&.id || @box&.category&.id,
        input_html: { class: "form-select verify-select" } %>
  </div>

  <%# Barcode %>
  <details class="barcode-details mb-2" <%= 'open' if @toy.barcode.present? %>>
    <summary class="barcode-summary">
      <i class="fa-solid fa-barcode"></i>
      <span>Code-barres</span>
    </summary>
    <%= f.input :barcode, label: false,
        input_html: { class: "form-control verify-input mt-2", placeholder: "Code-barres" } %>
  </details>

  <%# État %>
  <div class="verify-conditions mb-2">
    <%= f.check_box :french, class: "condition-toggle-input", id: "toy_french" %>
    <%= f.label :french, class: "condition-toggle-label", for: "toy_french" do %>
      <i class="fa-solid fa-flag"></i><span>Français</span>
    <% end %>
    <%= f.check_box :ce_mark, class: "condition-toggle-input", id: "toy_ce_mark" %>
    <%= f.label :ce_mark, class: "condition-toggle-label", for: "toy_ce_mark" do %>
      <i class="fa-solid fa-certificate"></i><span>CE / Marque</span>
    <% end %>
    <%= f.check_box :safe, class: "condition-toggle-input", id: "toy_safe" %>
    <%= f.label :safe, class: "condition-toggle-label", for: "toy_safe" do %>
      <i class="fa-solid fa-lock"></i><span>Sécurité</span>
    <% end %>
    <%= f.check_box :complete, class: "condition-toggle-input", id: "toy_complete" %>
    <%= f.label :complete, class: "condition-toggle-label", for: "toy_complete" do %>
      <i class="fa-solid fa-list-check"></i><span>Complet</span>
    <% end %>
    <%= f.check_box :playable, class: "condition-toggle-input", id: "toy_playable" %>
    <%= f.label :playable, class: "condition-toggle-label", for: "toy_playable" do %>
      <i class="fa-solid fa-gamepad"></i><span>Jouable</span>
    <% end %>
    <%= f.check_box :clean, class: "condition-toggle-input", id: "toy_clean" %>
    <%= f.label :clean, class: "condition-toggle-label", for: "toy_clean" do %>
      <i class="fa-solid fa-soap"></i><span>Propre</span>
    <% end %>
  </div>


  <%# Note vocale — opérateurs non-admin uniquement %>
  <% unless current_user.admin? %>
    <div class="vocal-section mb-3" data-controller="voice-recorder">
      <div class="vocal-header">
        <span class="vocal-label">
          <i class="fa-solid fa-microphone me-1" style="color:#FF6B35;"></i>Note vocale
        </span>
        <div class="vocal-controls">
          <button type="button"
                  class="vocal-btn vocal-btn-record"
                  data-voice-recorder-target="button"
                  data-action="click->voice-recorder#toggle"
                  title="Enregistrer">
            <i class="fa-solid fa-microphone" data-voice-recorder-target="icon"></i>
          </button>
          <button type="button"
                  class="vocal-btn vocal-btn-clear"
                  data-action="click->voice-recorder#clear"
                  title="Effacer">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
      </div>
      <span class="vocal-status" data-voice-recorder-target="status"></span>
      <%= f.input :operator_note,
          label: false,
          as: :text,
          placeholder: "Appuyez sur le micro pour dicter, ou écrivez directement…",
          input_html: {
            class: "form-control verify-input vocal-textarea",
            rows: 4,
            data: { "voice-recorder-target": "textarea" }
          } %>
    </div>
  <% end %>

  <% if @toy.admin_comment.present? %>
    <div class="mb-3" style="background:#f9f5f0; padding:0.75rem; border-radius:0.375rem; border-left:3px solid #FF6B35;">
      <div style="font-size:0.75rem; color:#9CA3AF; margin-bottom:0.3rem;">
        <i class="fa-solid fa-shield-halved me-1" style="color:#FF6B35;"></i>Commentaire admin
      </div>
      <div style="font-size:0.9rem; color:#1A2B4A;"><%= @toy.admin_comment %></div>
    </div>
  <% end %>

  <div class="d-grid">
    <button type="submit" class="btn btn-primary btn-lg">
      <i class="fa-solid fa-check" style="font-size:1.5rem; color:white;"></i>
    </button>
  </div>

<% end %>
