<%= simple_form_for @toy.persisted? ? @toy : [@box, @toy] do |f| %>

  <%# Photo %>
  <div class="mb-4">
    <label class="form-label">Photo du jouet</label>
    <% if @toy.photo.attached? %>
      <div class="mb-2 text-center">
        <%= image_tag @toy.photo, class: "current-photo d-block mx-auto" %>
        <span style="font-size:0.78rem; color:#9CA3AF; margin-top:0.3rem; display:block;">Photo actuelle</span>
      </div>
    <% end %>
    <div class="photo-upload-zone" id="photo-drop-zone">
      <div class="upload-icon"><i class="fa-solid fa-camera"></i></div>
      <%= f.input :photo,
        as: :file,
        label: false,
        input_html: { class: "form-control", id: "toy-photo-input", accept: "image/*",
                      style: "background:transparent; border:none; padding:0; font-size:0.85rem;" } %>
      <div id="photo-preview" class="mt-2 text-center"></div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const photoInput = document.getElementById('toy-photo-input');
      const previewContainer = document.getElementById('photo-preview');
      if (photoInput) {
        photoInput.addEventListener('change', function(event) {
          previewContainer.innerHTML = '';
          if (event.target.files && event.target.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
              const img = document.createElement('img');
              img.src = e.target.result;
              img.style.maxWidth = '160px';
              img.style.borderRadius = '0.75rem';
              img.style.boxShadow = '0 2px 8px rgba(0,0,0,0.1)';
              img.alt = 'Aperçu';
              previewContainer.appendChild(img);
            };
            reader.readAsDataURL(event.target.files[0]);
          }
        });
      }
    });
  </script>

  <%# Catégorie %>
  <div class="mb-3">
    <%= f.association :category,
      label: "Catégorie du jouet",
      selected: @toy.category&.id || @box&.category&.id,
      input_html: { class: "form-select" },
      label_html: { class: "form-label" } %>
  </div>

  <%# Barcode %>
  <div class="mb-3">
    <%= f.input :barcode,
      label: "Code-barres / Référence (facultatif)",
      input_html: { class: "form-control", placeholder: "Scannez ou saisissez" },
      label_html: { class: "form-label" } %>
  </div>

  <%# État %>
  <div class="mb-2">
    <label class="form-label">État du jouet</label>
  </div>
  <div class="d-flex flex-column gap-2 mb-4">
    <div class="form-check-custom">
      <%= f.check_box :clean, class: "form-check-input", id: "toy_clean" %>
      <%= f.label :clean, class: "form-check-label", for: "toy_clean" do %>
        <i class="fa-solid fa-soap"></i> Le jouet est propre
      <% end %>
    </div>
    <div class="form-check-custom">
      <%= f.check_box :complete, class: "form-check-input", id: "toy_complete" %>
      <%= f.label :complete, class: "form-check-label", for: "toy_complete" do %>
        <i class="fa-solid fa-puzzle-piece"></i> Le jouet est complet (toutes les pièces présentes)
      <% end %>
    </div>
    <div class="form-check-custom">
      <%= f.check_box :playable, class: "form-check-input", id: "toy_playable" %>
      <%= f.label :playable, class: "form-check-label", for: "toy_playable" do %>
        <i class="fa-solid fa-gamepad"></i> Le jouet est fonctionnel
      <% end %>
    </div>
  </div>

  <div class="d-grid">
    <%= f.button :submit, class: "btn btn-primary btn-lg" %>
  </div>

<% end %>
