<% content_for :title, "Jouets · RE-PLAY" %>

<div class="container py-4">
  <div class="page-header">
    <div>
      <h1 class="page-title"><span style="display:inline-block; position:relative; width:1.4em; height:1em; vertical-align:middle;" class="me-2"><i class="fa-solid fa-puzzle-piece" style="position:absolute; font-size:0.75em; top:0; left:0; color:#FF6B35;"></i><i class="fa-solid fa-puzzle-piece" style="position:absolute; font-size:0.75em; bottom:0; right:0; transform:rotate(90deg); color:#FF6B35;"></i></span>Jouets</h1>
      <p class="page-subtitle">
        <% if params[:filter] == "validated" %>
          Jouets reconditionnés et validés
        <% elsif params[:filter] == "deleted" %>
          Jouets jetés
        <% else %>
          Jouets en attente de contrôle qualité
        <% end %>
      </p>
    </div>
    <%= link_to boxes_path, class: "btn-back-boxes", title: "Retour aux boîtes" do %>
      <span style="color:#000;">←</span> <i class="fa-solid fa-boxes-stacked"></i>
    <% end %>
  </div>

  <div class="mb-4">
    <div class="filter-tabs">
      <%= link_to toys_path,
            class: "filter-tab filter-tab-waiting #{'active' if params[:filter].blank?}" do %>
        <i class="fa-solid fa-hourglass-half"></i>
        Attente
        <span class="filter-count"><%= Toy.waiting.count %></span>
      <% end %>
      <%= link_to toys_path(filter: "validated"),
            class: "filter-tab filter-tab-validated #{'active' if params[:filter] == 'validated'}" do %>
        <i class="fa-solid fa-store"></i>
        Prêts
        <span class="filter-count"><%= Toy.validated.count %></span>
      <% end %>
      <%= link_to toys_path(filter: "deleted"),
            class: "filter-tab filter-tab-deleted #{'active' if params[:filter] == 'deleted'}" do %>
        <i class="fa-solid fa-trash-can"></i>
        Jetés
        <span class="filter-count"><%= Toy.deleted.count %></span>
      <% end %>
    </div>
  </div>

  <% if @toys.empty? %>
    <div class="text-center py-5">
      <div style="font-size: 4rem; color: rgba(255,107,53,0.2); margin-bottom: 1rem;">
        <i class="fa-solid fa-puzzle-piece"></i>
      </div>
      <h3 style="color: #6B7280;">Aucun jouet ici</h3>
      <p style="color: #9CA3AF;">
        <% if params[:filter] == "validated" %>
          Aucun jouet validé pour le moment.
        <% else %>
          Tous les jouets sont validés !
        <% end %>
      </p>
    </div>
  <% else %>
    <div class="row g-3">
      <% @toys.each do |toy| %>
        <div class="col-12 col-sm-6 col-md-4 col-xl-3">
          <div class="toy-card">
            <div class="toy-card-photo-wrap">
              <% if toy.photo.attached? %>
                <%= image_tag toy.photo, class: "toy-card-img" %>
              <% else %>
                <div class="toy-card-no-img"><i class="fa-solid fa-image"></i></div>
              <% end %>
              <% if toy.price.present? %>
                <div class="toy-card-price-badge"><%= toy.price.to_i %> €</div>
              <% end %>
              <% if toy.suppr? %>
                <span class="status-dot status-dot-deleted toy-card-status-dot" title="Jeté"></span>
              <% elsif toy.market? %>
                <span class="status-dot status-dot-validated toy-card-status-dot" title="Validé"></span>
              <% else %>
                <span class="status-dot status-dot-waiting toy-card-status-dot" title="En attente de validation"></span>
              <% end %>
              <div class="toy-card-actions">
                <%= link_to toy_path(toy), class: "toy-action-btn toy-action-primary", title: "Voir" do %>
                  <i class="fa-solid fa-eye"></i>
                <% end %>
                <% if policy(toy).verify? %>
                  <%= link_to verify_toy_path(toy), class: "toy-action-btn toy-action-verify", title: "Contrôle qualité" do %>
                    <i class="fa-solid fa-magnifying-glass"></i>
                  <% end %>
                <% end %>
                <% if policy(toy).edit? %>
                  <%= link_to edit_toy_path(toy), class: "toy-action-btn toy-action-edit", title: "Modifier" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                <% end %>
                <% if policy(toy).restore? && toy.suppr? %>
                  <%= button_to restore_toy_path(toy), method: :patch, class: "toy-action-btn toy-action-restore", title: "Réintégrer" do %>
                    <i class="fa-solid fa-rotate-left"></i>
                  <% end %>
                <% end %>
                <% if policy(toy).destroy? && !toy.suppr? %>
                  <%= link_to toy_path(toy),
                        class: "toy-action-btn toy-action-delete",
                        title: "Supprimer",
                        data: { turbo_method: :delete, turbo_confirm: "Supprimer ce jouet ?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                <% end %>
              </div>
            </div>
            <div class="toy-card-body">
              <div class="toy-card-title">
                <% if toy.suppr? %>
                  <i class="fa-solid fa-trash-can me-1"></i>
                <% elsif toy.market? %>
                  <i class="fa-solid fa-store me-1"></i>
                <% else %>
                  <i class="fa-solid fa-hourglass-half me-1"></i>
                <% end %>
                N°&nbsp;<%= toy.id %>
              </div>
              <div class="toy-card-meta">
                <span class="toy-card-category"><i class="fa-solid fa-layer-group me-1"></i><%= truncate(toy.category.name, length: 20) %></span>
                <div class="toy-card-conditions">
                  <span class="condition-icon <%= toy.clean? ? 'ok' : 'ko' %>" title="<%= toy.clean? ? 'Propre' : 'Pas propre' %>">
                    <i class="fa-solid fa-soap"></i>
                  </span>
                  <span class="condition-icon <%= toy.complete? ? 'ok' : 'ko' %>" title="<%= toy.complete? ? 'Complet' : 'Incomplet' %>">
                    <i class="fa-solid fa-list-check"></i>
                  </span>
                  <span class="condition-icon <%= toy.playable? ? 'ok' : 'ko' %>" title="<%= toy.playable? ? 'Jouable' : 'Non jouable' %>">
                    <i class="fa-solid fa-gamepad"></i>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
