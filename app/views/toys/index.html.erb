<% content_for :title, "Jouets · RE-PLAY" %>

<div class="container py-4">
  <div class="page-header">
    <div>
      <h1 class="page-title"><i class="fa-solid fa-puzzle-piece me-2" style="color:#FF6B35;"></i>Jouets</h1>
      <p class="page-subtitle">
        <% if params[:filter] == "validated" %>
          Jouets reconditionnés et validés
        <% else %>
          Jouets en attente de contrôle qualité
        <% end %>
      </p>
    </div>
    <%= link_to boxes_path, class: "btn btn-ghost btn-sm" do %>
      <i class="fa-solid fa-box me-1"></i>Boîtes
    <% end %>
  </div>

  <div class="mb-4">
    <div class="filter-tabs">
      <%= link_to toys_path,
            class: "filter-tab #{'active' unless params[:filter] == 'validated'}" do %>
        <i class="fa-solid fa-clock"></i>
        En attente
        <span style="background: rgba(255,107,53,0.15); color: #FF6B35; padding: 0.1em 0.5em; border-radius: 50rem; font-size: 0.75em;">
          <%= Toy.waiting.count %>
        </span>
      <% end %>
      <%= link_to toys_path(filter: "validated"),
            class: "filter-tab #{'active' if params[:filter] == 'validated'}" do %>
        <i class="fa-solid fa-circle-check"></i>
        Validés
        <span style="background: rgba(12,201,163,0.15); color: #0CC9A3; padding: 0.1em 0.5em; border-radius: 50rem; font-size: 0.75em;">
          <%= Toy.validated.count %>
        </span>
      <% end %>
    </div>
  </div>

  <% if @toys.empty? %>
    <div class="text-center py-5">
      <div style="font-size: 4rem; color: rgba(255,107,53,0.2); margin-bottom: 1rem;">
        <i class="fa-solid fa-puzzle-piece"></i>
      </div>
      <h3 style="color: #6B7280;">Aucun jouet ici</h3>
      <p style="color: #9CA3AF;">
        <% if params[:filter] == "validated" %>
          Aucun jouet validé pour le moment.
        <% else %>
          Tous les jouets sont validés !
        <% end %>
      </p>
    </div>
  <% else %>
    <div class="row g-3">
      <% @toys.each do |toy| %>
        <div class="col-sm-6 col-md-4 col-xl-3">
          <div class="toy-card">
            <% if toy.photo.attached? %>
              <%= image_tag toy.photo, class: "toy-card-img" %>
            <% else %>
              <div class="toy-card-no-img"><i class="fa-solid fa-image"></i></div>
            <% end %>
            <div class="toy-card-body">
              <div class="toy-card-title">Jouet #<%= toy.id %></div>
              <div class="toy-card-meta">
                <i class="fa-solid fa-tag"></i><%= toy.category.name %>
              </div>
              <div class="toy-card-badges">
                <% if toy.pending? %>
                  <span class="badge badge-waiting"><i class="fa-solid fa-clock me-1"></i>En attente</span>
                <% elsif toy.review? %>
                  <span class="badge" style="background:rgba(155,93,229,0.15);color:#7B2FBE;font-weight:700;"><i class="fa-solid fa-magnifying-glass me-1"></i>En contrôle</span>
                <% elsif toy.market? %>
                  <span class="badge badge-validated"><i class="fa-solid fa-check me-1"></i>En vente</span>
                <% elsif toy.suppr? %>
                  <span class="badge" style="background:rgba(230,57,70,0.1);color:#E63946;font-weight:700;"><i class="fa-solid fa-trash me-1"></i>Supprimé</span>
                <% end %>
                <% if toy.clean? %>
                  <span class="condition-pill ok"><i class="fa-solid fa-soap"></i>Propre</span>
                <% end %>
              </div>
              <% if toy.price.present? %>
                <div class="toy-card-price">
                  <%= toy.price.to_i %> €<span> suggéré par IA</span>
                </div>
              <% end %>
              <div class="toy-card-actions">
                <%= link_to toy_path(toy), class: "btn btn-primary btn-sm" do %>
                  Voir
                <% end %>
                <% if policy(toy).verify? %>
                  <%= link_to verify_toy_path(toy), class: "btn btn-sm", style: "background:rgba(155,93,229,0.12);color:#9B5DE5;font-weight:700;" do %>
                    <i class="fa-solid fa-magnifying-glass"></i>
                  <% end %>
                <% end %>
                <% if policy(toy).edit? %>
                  <%= link_to edit_toy_path(toy), class: "btn btn-ghost btn-sm btn-icon" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                <% end %>
                <% if policy(toy).destroy? %>
                  <%= link_to toy_path(toy),
                        class: "btn btn-sm btn-icon",
                        style: "background:rgba(230,57,70,0.1);color:#E63946;",
                        data: { turbo_method: :delete, turbo_confirm: "Supprimer ce jouet ?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
