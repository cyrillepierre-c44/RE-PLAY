<% content_for :title, "Jouets · RE-PLAY" %>

<div class="container py-4">
  <div class="page-header mb-4">
    <%= link_to boxes_path, class: "btn-back-boxes", title: "Retour aux caisses" do %>
      <i class="fa-solid fa-circle-arrow-left"></i>
      <i class="fa-solid fa-boxes-stacked btn-back-context-icon"></i>
    <% end %>
    <div style="text-align: right;">
      <h1 class="page-title"><%= toys_icon(html_class: "me-2", style: "color:#FF6B35;") %>Jouets</h1>
      <p class="page-subtitle">
        <% if params[:filter] == "validated" %>
          Jouets reconditionnés et validés
        <% elsif params[:filter] == "sold" %>
          Jouets vendus
        <% elsif params[:filter] == "deleted" %>
          Jouets jetés
        <% else %>
          Jouets en attente de contrôle qualité
        <% end %>
      </p>
    </div>
  </div>

  <div class="mb-3">
    <%= form_with url: toys_path, method: :get, local: true do |f| %>
      <%= hidden_field_tag :filter, params[:filter] if params[:filter].present? %>
      <%= hidden_field_tag :category_id, params[:category_id] if params[:category_id].present? %>
      <div class="input-group search-id-group">
        <span class="input-group-text search-id-prefix">J</span>
        <%= f.text_field :q,
              value: params[:q].to_s.gsub(/\D/, ''),
              placeholder: "Numéro de jouet",
              inputmode: "numeric",
              pattern: "[0-9]*",
              autocomplete: "off",
              class: "form-control search-id-input" %>
        <% if params[:q].present? %>
          <%= link_to toys_path(filter: params[:filter], category_id: params[:category_id]),
                class: "btn search-id-clear" do %>
            <i class="fa-solid fa-xmark"></i>
          <% end %>
        <% end %>
        <button type="submit" class="btn search-id-submit">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <div class="filter-tabs filter-tabs-toys">
      <%= link_to toys_path(category_id: params[:category_id]),
            class: "filter-tab filter-tab-waiting filter-tab-full #{'active' if params[:filter].blank? || params[:filter] == 'waiting'}" do %>
        <i class="fa-solid fa-clock"></i>
        Attente
        <span class="filter-count"><%= @count_scope.waiting.count %></span>
      <% end %>
      <div class="filter-tabs-sub-row">
        <%= link_to toys_path(filter: "validated", category_id: params[:category_id]),
              class: "filter-tab filter-tab-validated #{'active' if params[:filter] == 'validated'}" do %>
          <i class="fa-solid fa-store"></i>
          <span class="tab-label">Prêts</span>
          <span class="filter-count"><%= @count_scope.validated.available.count %></span>
        <% end %>
        <%= link_to toys_path(filter: "sold", category_id: params[:category_id]),
              class: "filter-tab filter-tab-sold #{'active' if params[:filter] == 'sold'}" do %>
          <i class="fa-solid fa-tag"></i>
          <span class="tab-label">Vendus</span>
          <span class="filter-count"><%= @count_scope.validated.sold.count %></span>
        <% end %>
        <%= link_to toys_path(filter: "deleted", category_id: params[:category_id]),
              class: "filter-tab filter-tab-deleted #{'active' if params[:filter] == 'deleted'}" do %>
          <i class="fa-solid fa-trash-can"></i>
          <span class="tab-label">Jetés</span>
          <span class="filter-count"><%= @count_scope.deleted.count %></span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mb-4">
    <%= form_with url: toys_path, method: :get, local: true do |f| %>
      <%= hidden_field_tag :filter, params[:filter] %>
      <%= f.select :category_id,
            options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
            { include_blank: "Toutes les catégories" },
            { class: "form-select category-filter-select", onchange: "this.form.requestSubmit()" } %>
    <% end %>
  </div>

  <% if params[:filter] == "deleted" && current_user.admin? && @toys.any? %>
    <div class="mb-3 text-end">
      <%= button_to "Vider définitivement la corbeille",
            purge_deleted_toys_path,
            method: :delete,
            data: { turbo_confirm: "Supprimer définitivement #{@toys.count} jouet(s) ? Cette action est irréversible." },
            class: "btn btn-sm",
            style: "background:rgba(230,57,70,0.1);color:#E63946;font-weight:700;" %>
    </div>
  <% end %>

  <% if @toys.empty? %>
    <div class="text-center py-5">
      <div style="font-size: 4rem; color: rgba(255,107,53,0.2); margin-bottom: 1rem;">
        <%= toys_icon(style: "width:1.3em;height:1.3em;") %>
      </div>
      <h3 style="color: #6B7280;">Aucun jouet ici</h3>
      <p style="color: #9CA3AF;">
        <% if params[:filter] == "validated" %>
          Aucun jouet disponible pour le moment.
        <% elsif params[:filter] == "sold" %>
          Aucun jouet vendu pour le moment.
        <% else %>
          Tous les jouets sont validés !
        <% end %>
      </p>
    </div>
  <% else %>
    <div class="row g-3">
      <% @toys.each do |toy| %>
        <div class="col-12 col-sm-6 col-md-4 col-xl-3">
          <%= link_to toy_path(toy, back_filter: params[:filter]), class: "toy-card #{'toy-card--sold' if toy.sold?}" do %>
            <div class="toy-card-photo-wrap">
              <% if toy.photo.attached? %>
                <%= image_tag toy.photo, class: "toy-card-img" %>
              <% else %>
                <div class="toy-card-no-img"><i class="fa-solid fa-image"></i></div>
              <% end %>
              <% if toy.price.present? %>
                <div class="toy-card-price-badge"><%= toy.price.to_i %> €</div>
              <% end %>
              <% if toy.suppr? %>
                <span class="status-dot status-dot-deleted toy-card-status-dot" title="Jeté"></span>
              <% elsif toy.market? %>
                <span class="status-dot status-dot-validated toy-card-status-dot" title="Validé"></span>
              <% elsif toy.review? %>
                <span class="status-dot status-dot-review toy-card-status-dot" title="Contrôle qualité refusé"></span>
                <div class="toy-card-review-badge">
                  <i class="fa-solid fa-triangle-exclamation"></i> CQ refusé
                </div>
              <% else %>
                <span class="status-dot status-dot-waiting toy-card-status-dot" title="En attente de validation"></span>
              <% end %>
              <% if toy.sold? %>
                <div class="toy-card-sold-badge">
                  <i class="fa-solid fa-tag"></i> Vendu
                </div>
              <% end %>
            </div>
            <div class="toy-card-body">
              <div class="toy-card-title">
                <% if toy.suppr? %>
                  <i class="fa-solid fa-trash-can me-1"></i>
                <% elsif toy.market? %>
                  <i class="fa-solid fa-store me-1"></i>
                <% elsif toy.review? %>
                  <i class="fa-solid fa-triangle-exclamation me-1" style="color:#F97316;"></i>
                <% else %>
                  <i class="fa-solid fa-clock me-1"></i>
                <% end %>
                J<%= toy.id %>
              </div>
              <div class="toy-card-meta">
                <span class="toy-card-category"><i class="fa-solid <%= toy.category.icon.presence || 'fa-tag' %> me-1"></i><%= truncate(toy.category.name, length: 20) %></span>
                <div class="toy-card-conditions">
                  <span class="condition-icon <%= toy.french? ? 'ok' : 'ko' %>" title="<%= toy.french? ? 'Français' : 'Pas en français' %>">
                    <i class="fa-solid fa-flag"></i>
                  </span>
                  <span class="condition-icon <%= toy.ce_mark? ? 'ok' : 'ko' %>" title="<%= toy.ce_mark? ? 'CE / Marque connue' : 'Sans CE ni marque' %>">
                    <i class="fa-solid fa-award"></i>
                  </span>
                  <span class="condition-icon <%= toy.safe? ? 'ok' : 'ko' %>" title="<%= toy.safe? ? 'Sécurité OK' : 'Sécurité non vérifiée' %>">
                    <i class="fa-solid fa-lock"></i>
                  </span>
                  <span class="condition-icon <%= toy.complete? ? 'ok' : 'ko' %>" title="<%= toy.complete? ? 'Complet' : 'Incomplet' %>">
                    <i class="fa-solid fa-list-check"></i>
                  </span>
                  <span class="condition-icon <%= toy.playable? ? 'ok' : 'ko' %>" title="<%= toy.playable? ? 'Jouable' : 'Non jouable' %>">
                    <i class="fa-solid fa-gamepad"></i>
                  </span>
                  <span class="condition-icon <%= toy.clean? ? 'ok' : 'ko' %>" title="<%= toy.clean? ? 'Propre' : 'Pas propre' %>">
                    <i class="fa-solid fa-soap"></i>
                  </span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
