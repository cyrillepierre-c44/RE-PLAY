<% content_for :title, "Contrôle qualité · Jouet ##{@toy.id} · RE-PLAY" %>

<div class="form-page">
  <div class="container">
    <%= link_to toy_path(@toy), class: "btn btn-ghost btn-sm mb-3" do %>
      <i class="fa-solid fa-arrow-left me-1"></i>Retour au jouet #<%= @toy.id %>
    <% end %>

    <div class="form-card" style="max-width: 620px;">
      <div class="form-card-header" style="background: linear-gradient(135deg, rgba(155,93,229,0.08), rgba(76,201,240,0.08));">
        <div class="form-card-icon" style="background: linear-gradient(135deg, rgba(155,93,229,0.15), rgba(76,201,240,0.2)); color: #9B5DE5;">
          <i class="fa-solid fa-clipboard-check"></i>
        </div>
        <h1 class="form-card-title">Contrôle qualité</h1>
        <p class="form-card-subtitle">
          Jouet #<%= @toy.id %> · <%= @toy.category.name %>
        </p>
      </div>

      <div class="form-card-body">
        <% if @toy.photo.attached? %>
          <div class="text-center mb-4">
            <%= image_tag @toy.photo, class: "current-photo", style: "max-width: 240px; display: block; margin: 0 auto;" %>
          </div>
        <% end %>

        <%= simple_form_for(@toy, url: confirm_verify_toy_path(@toy), method: :patch) do |f| %>

          <%# Photo update %>
          <div class="mb-3">
            <label class="form-label">Mettre à jour la photo</label>
            <div class="photo-upload-zone">
              <div class="upload-icon"><i class="fa-solid fa-camera"></i></div>
              <%= f.input :photo,
                as: :file,
                label: false,
                input_html: { class: "form-control", id: "toy-photo-input", accept: "image/*",
                              style: "background:transparent; border:none; padding:0; font-size:0.85rem;" } %>
              <div id="photo-preview" class="mt-2 text-center"></div>
            </div>
          </div>

          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const photoInput = document.getElementById('toy-photo-input');
              const previewContainer = document.getElementById('photo-preview');
              if (photoInput) {
                photoInput.addEventListener('change', function(event) {
                  previewContainer.innerHTML = '';
                  if (event.target.files && event.target.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                      const img = document.createElement('img');
                      img.src = e.target.result;
                      img.style.maxWidth = '200px';
                      img.style.borderRadius = '0.75rem';
                      img.alt = 'Aperçu';
                      previewContainer.appendChild(img);
                    };
                    reader.readAsDataURL(event.target.files[0]);
                  }
                });
              }
            });
          </script>

          <%# Catégorie %>
          <div class="mb-3">
            <%= f.association :category,
              label: "Catégorie",
              input_html: { class: "form-select" },
              label_html: { class: "form-label" } %>
          </div>

          <%# Barcode %>
          <div class="mb-3">
            <%= f.input :barcode,
              label: "Code-barres / Référence",
              input_html: { class: "form-control" },
              label_html: { class: "form-label" } %>
          </div>

          <%# État %>
          <div class="mb-2">
            <label class="form-label">État du jouet</label>
          </div>
          <div class="d-flex flex-column gap-2 mb-4">
            <div class="form-check-custom">
              <%= f.check_box :clean, class: "form-check-input", id: "toy_clean" %>
              <%= f.label :clean, class: "form-check-label", for: "toy_clean" do %>
                <i class="fa-solid fa-soap"></i> Propre
              <% end %>
            </div>
            <div class="form-check-custom">
              <%= f.check_box :complete, class: "form-check-input", id: "toy_complete" %>
              <%= f.label :complete, class: "form-check-label", for: "toy_complete" do %>
                <i class="fa-solid fa-puzzle-piece"></i> Complet
              <% end %>
            </div>
            <div class="form-check-custom">
              <%= f.check_box :playable, class: "form-check-input", id: "toy_playable" %>
              <%= f.label :playable, class: "form-check-label", for: "toy_playable" do %>
                <i class="fa-solid fa-gamepad"></i> Fonctionnel
              <% end %>
            </div>
          </div>

          <%# Prix %>
          <div class="mb-3">
            <%= f.input :price,
              label: "Prix de vente (€)",
              as: :numeric,
              input_html: { class: "form-control", step: 0.01 },
              label_html: { class: "form-label" } %>
          </div>

          <%# Emplacement %>
          <div class="mb-4">
            <%= f.input :location,
              label: "Emplacement de rangement",
              required: true,
              input_html: {
                class: "form-control",
                placeholder: "Ex: Rack A, Étagère 2, Boîte 5",
                value: @toy.location == "En attente de validation" ? "" : @toy.location
              },
              label_html: { class: "form-label" },
              hint: "Indiquez où le jouet sera stocké après validation." %>
          </div>

          <div class="d-flex gap-2 flex-wrap">
            <%= f.button :submit, "Valider & mettre en vente",
                  name: "submit_action", value: "validate",
                  class: "btn btn-primary flex-fill" %>
            <%= f.button :submit, "Retour en valorisation",
                  name: "submit_action", value: "rework",
                  class: "btn btn-ghost flex-fill" %>
            <% if policy(@toy).destroy? %>
              <%= link_to toy_path(@toy),
                    class: "btn flex-fill",
                    style: "background:rgba(230,57,70,0.1);color:#E63946;font-weight:700;",
                    data: { turbo_method: :delete, turbo_confirm: "Supprimer ce jouet ?" } do %>
                <i class="fa-solid fa-trash me-1"></i>Supprimer
              <% end %>
            <% end %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>
