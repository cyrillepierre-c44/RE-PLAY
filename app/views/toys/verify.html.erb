<% content_for :title, "Contrôle qualité · Jouet N°#{@toy.id} · RE-PLAY" %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <%= link_to toy_path(@toy), class: "btn-back-boxes" do %>
      <span style="color:#000;">←</span>
      <i class="fa-solid fa-puzzle-piece"></i>
    <% end %>
    <span class="toy-show-category-badge" style="font-size:2rem; max-width:none;"><i class="fa-solid fa-puzzle-piece me-1"></i>N°&nbsp;<%= @toy.id %></span>
  </div>

  <div class="verify-header mb-3">
    <h1 class="toy-show-title">
      <i class="fa-solid fa-magnifying-glass me-2"></i>Contrôle qualité
    </h1>
  </div>

  <%= simple_form_for(@toy, url: confirm_verify_toy_path(@toy), method: :patch) do |f| %>

    <div class="row g-3">

      <%# ── Photo ── %>
      <div class="col-12 col-md-4">
        <div class="verify-photo-wrap">
          <% if @toy.photo.attached? %>
            <%= image_tag @toy.photo, class: "verify-photo", id: "photo-preview-img" %>
          <% else %>
            <div class="verify-no-photo" id="photo-preview-img">
              <i class="fa-solid fa-image"></i>
            </div>
          <% end %>
          <label class="verify-photo-overlay" for="toy-photo-input" title="Changer la photo">
            <i class="fa-solid fa-camera"></i>
          </label>
          <%= f.input :photo,
              as: :file,
              label: false,
              input_html: { id: "toy-photo-input", accept: "image/*", style: "display:none;" } %>
          <div id="photo-new-preview" class="mt-2 text-center" style="display:none;">
            <img id="photo-preview-new" src="" style="max-width:100%; border-radius:0.75rem;" alt="Aperçu">
          </div>
        </div>
      </div>

      <%# ── Champs & conditions ── %>
      <div class="col-12 col-md-8">

        <%# Conditions toggle %>
        <div class="verify-conditions mb-3">
          <input type="hidden" name="toy[clean]" value="0">
          <input type="checkbox" name="toy[clean]" value="1" id="toggle-clean" class="condition-toggle-input" <%= 'checked' if @toy.clean? %>>
          <label for="toggle-clean" class="condition-toggle-label">
            <i class="fa-solid fa-soap"></i>
            <span>Propre</span>
          </label>

          <input type="hidden" name="toy[complete]" value="0">
          <input type="checkbox" name="toy[complete]" value="1" id="toggle-complete" class="condition-toggle-input" <%= 'checked' if @toy.complete? %>>
          <label for="toggle-complete" class="condition-toggle-label">
            <i class="fa-solid fa-puzzle-piece"></i>
            <span>Complet</span>
          </label>

          <input type="hidden" name="toy[playable]" value="0">
          <input type="checkbox" name="toy[playable]" value="1" id="toggle-playable" class="condition-toggle-input" <%= 'checked' if @toy.playable? %>>
          <label for="toggle-playable" class="condition-toggle-label">
            <i class="fa-solid fa-gamepad"></i>
            <span>Jouable</span>
          </label>
        </div>

        <%# Catégorie %>
        <div class="mb-2">
          <%= f.association :category,
              label: false,
              prompt: "Catégorie…",
              input_html: { class: "form-select verify-select" } %>
        </div>

        <%# Barcode + Prix côte à côte %>
        <div class="row g-2 mb-2">
          <div class="col-6">
            <%= f.input :barcode,
                label: false,
                placeholder: "Code-barres",
                input_html: { class: "form-control verify-input" } %>
          </div>
          <div class="col-6">
            <%= f.input :price,
                label: false,
                as: :numeric,
                placeholder: "Prix (€)",
                input_html: { class: "form-control verify-input", step: 0.01 } %>
          </div>
        </div>

        <%# Emplacement %>
        <div class="mb-3">
          <%= f.input :location,
              label: false,
              required: true,
              placeholder: "Emplacement : Rack A, Étagère 0…",
              input_html: { class: "form-control verify-input", value: @toy.location.presence || "Rack A, Étagère 0, Boîte 0" } %>
        </div>

        <%# Boutons décision %>
        <div class="verify-decisions">
          <%= button_tag name: :status, value: "market", class: "verify-btn verify-btn-market" do %>
            <i class="fa-solid fa-tag"></i>
            <span>Mise en vente</span>
          <% end %>
          <%= button_tag name: :status, value: "review", class: "verify-btn verify-btn-review" do %>
            <i class="fa-solid fa-rotate-left"></i>
            <span>Revaloriser</span>
          <% end %>
          <%= button_tag name: :status, value: "suppr", class: "verify-btn verify-btn-suppr",
              data: { confirm: "Supprimer définitivement ce jouet ?" } do %>
            <i class="fa-solid fa-trash"></i>
            <span>Jeter</span>
          <% end %>
        </div>

      </div>
    </div>

  <% end %>
</div>

<script>
  document.getElementById('toy-photo-input').addEventListener('change', function(e) {
    if (e.target.files && e.target.files[0]) {
      const reader = new FileReader();
      reader.onload = function(ev) {
        const preview = document.getElementById('photo-preview-new');
        preview.src = ev.target.result;
        document.getElementById('photo-new-preview').style.display = 'block';
      };
      reader.readAsDataURL(e.target.files[0]);
    }
  });
</script>
