<h1>formulaire de validation du jouet</h1>

<div class="container" >
  <div class="request-form">
<%= simple_form_for(@toy, url: confirm_verify_toy_path(@toy), method: :patch) do |f| %>

      <div class="mb-3">
        <%= f.input :photo,
          as: :file,
          label: "Photo de l'objet",
          input_html: { class: "form-control", id: "toy-photo-input", accept: "image/*" },
          label_html: { class: "form-label" } %>
        <div id="photo-preview" class="mt-2 text-center"></div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const photoInput = document.getElementById('toy-photo-input');
          const previewContainer = document.getElementById('photo-preview');

          if (photoInput) {
            photoInput.addEventListener('change', function(event) {
              previewContainer.innerHTML = '';

              if (event.target.files && event.target.files[0]) {
                const reader = new FileReader();

                reader.onload = function(e) {
                  const img = document.createElement('img');
                  img.src = e.target.result;
                  img.className = 'img-thumbnail';
                  img.style.maxWidth = '200px';
                  img.alt = 'Aperçu de la photo';
                  previewContainer.appendChild(img);
                };

                reader.readAsDataURL(event.target.files[0]);
              }
            });
          }
        });
      </script>

      <% if @toy.photo.attached? %>
        <div class="mb-3 text-center">
          <%= image_tag @toy.photo, class: "img-thumbnail", style: "max-width: 200px;", alt: "Photo actuelle du jouet" %>
          <p class="text-muted small">Photo actuelle</p>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.association :category,
          label: "Catégorie du jouet",
          input_html: { class: "form-control", value: @box.category.name } %>
      </div>

      <div class="mb-3">
        <%= f.input :barcode,
          label: "Identification du jouet (facultatif)",
          input_html: { class: "form-control" } %>
      </div>

      <div class="mb-3 form-check">
        <%= f.input :clean,
          label: "Cocher si le jouet est propre",
          input_html: { class: "form-check-input" },
          wrapper_html: { class: "form-check" } %>
      </div>

      <div class="mb-3 form-check">
        <%= f.input :complete,
          label: "Cocher si le jouet est complet",
          input_html: { class: "form-check-input" },
          wrapper_html: { class: "form-check" } %>
      </div>

      <div class="mb-3 form-check">
        <%= f.input :playable,
          label: "Cocher si le jouet est jouable",
          input_html: { class: "form-check-input" },
          wrapper_html: { class: "form-check" } %>
      </div>

      <div class="mb-3">
        <%= f.input :price,
          label: "Prix (€)",
          as: :numeric,
          input_html: { class: "form-control", step: 0.01 } %>
      </div>

      <div class="mb-3">
        <%= f.input :location,
          label: "Lieu où va etre rangé le jouet",
          required: true,
          placeholder: "Rack A, Etagère 0, Boîte 0",
          input_html: {
            class: "form-control",
              value: @toy.location || "Rack A, Etagère 0, Boîte 0"
          } %>
      </div>


      <div class="d-flex gap-2 justify-content-center">
        <%= f.button :submit, "Mise en vente", class: "btn btn-primary btn-lg flex-fill" %>
        <%= f.button :submit, "Retour en valorisation", class: "btn btn-warning btn-lg flex-fill" %>
        <%= link_to "Supprimer", toy_path(@toy), class: "btn btn-danger btn-lg flex-fill", data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr ?" } if policy(@toy).destroy? %>
      </div>


    <% end %>
  </div>
</div>
