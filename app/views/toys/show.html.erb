<h1>Details, du jouet en valorisation</h1>
<%= link_to "retour à la liste des jouets", toys_path, class: "btn btn-secondary mt-1" %>
<br>
<div class=container>
  <h3>Jouet numéro <%= @toy.id %>,
  catégorie : <%= @toy.category.name %>,
  <% if @toy.barcode.present? %>
  barcode : <%= @toy.barcode %>,
  <% end %>
  créé le : <%= @toy.created_at.day %>/<%= @toy.created_at.month %>/<%= @toy.created_at.year %>,
  </h3>
</div>
<%= link_to("Modifier", edit_toy_path(@toy), class: "btn btn-warning") if policy(@toy).edit? %>
<br>
<%= link_to("Supprimer", toy_path(@toy), class: "btn btn-danger", data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr ?" }) if policy(@toy).destroy? %>
</div>
