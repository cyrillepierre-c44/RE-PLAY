<% content_for :title, "Modifier le jouet N°#{@toy.id} · RE-PLAY" %>

<div class="container py-4">
  <%= link_to toy_path(@toy), class: "btn-back-boxes mb-3 d-inline-block" do %>
    <span style="color:#000;">←</span> <i class="fa-solid fa-puzzle-piece"></i>
  <% end %>

  <div class="detail-card p-4">
    <div class="d-flex align-items-center gap-3 mb-1">
      <div class="form-card-icon" style="margin-bottom:0; flex-shrink:0;">
        <i class="fa-solid fa-pen-to-square"></i>
      </div>
      <h1 class="toy-show-title" style="font-size:1.6rem;">Modifier le jouet N°<%= @toy.id %></h1>
    </div>
    <p style="font-size:1.15rem; font-weight:700; color:#1A2B4A; margin-bottom:1rem;"><%= @toy.category.name %></p>

    <%= render "form" %>
  </div>
</div>
