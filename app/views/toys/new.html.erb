<% content_for :title, "Nouveau jouet · RE-PLAY" %>

<div class="form-page">
  <div class="container">
    <%= link_to box_path(@box), class: "btn btn-ghost btn-sm mb-3" do %>
      <i class="fa-solid fa-arrow-left me-1"></i>Retour à la boîte #<%= @box.id %>
    <% end %>
    <div class="form-card">
      <div class="form-card-header">
        <div class="form-card-icon">
          <i class="fa-solid fa-puzzle-piece"></i>
        </div>
        <h1 class="form-card-title">Nouveau jouet</h1>
        <p class="form-card-subtitle">
          Boîte #<%= @box.id %> · <%= @box.category.name %>
        </p>
      </div>
      <div class="form-card-body">
        <%= render "form" %>
      </div>
    </div>
  </div>
</div>
