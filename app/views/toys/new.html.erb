<% content_for :title, "Nouveau jouet · Boîte N°#{@box.id} · RE-PLAY" %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <%= link_to box_path(@box), class: "btn-back-boxes" do %>
      <i class="fa-solid fa-circle-arrow-left"></i>
      <i class="fa-solid fa-box btn-back-context-icon"></i>
    <% end %>
    <span class="toy-show-category-badge" style="font-size:2rem; max-width:none;"><i class="fa-solid fa-box me-1"></i>N°&nbsp;<%= @box.id %></span>
  </div>

  <div class="detail-card p-4">
    <div class="d-flex align-items-center gap-3 mb-1">
      <div class="form-card-icon" style="margin-bottom:0; flex-shrink:0;">
        <i class="fa-solid fa-plus"></i>
      </div>
      <h1 class="toy-show-title" style="font-size:1.6rem;">Nouveau jouet</h1>
    </div>
    <p style="font-size:1.15rem; font-weight:700; color:#1A2B4A; margin-bottom:1rem;"><%= @box.category.name %></p>

<%= render "form" %>
  </div>
</div>
