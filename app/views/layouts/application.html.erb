<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <title><%= content_for(:title) || "RE-PLAY · Enjoué" %></title>
    <meta name="description" content="<%= content_for(:description) || "RE-PLAY by Enjoué — Gestion et reconditionnement de jouets d'occasion." %>">
    <meta name="robots" content="noindex, nofollow">
    <meta property="og:title" content="<%= content_for(:title) || "RE-PLAY · Enjoué" %>">
    <meta property="og:description" content="<%= content_for(:description) || "RE-PLAY by Enjoué — Gestion et reconditionnement de jouets d'occasion." %>">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="fr_FR">
    <meta property="og:site_name" content="RE-PLAY · Enjoué">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="application-name" content="RE-PLAY">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# ── Open Graph ─────────────────────────────────────────────────── %>
    <meta property="og:title"       content="<%= content_for(:title) || "RE-PLAY · Enjoué" %>">
    <meta property="og:description" content="La plateforme de gestion des jouets reconditionnés par ENJOUÉ — traçabilité digitale, contrôle qualité et prix assisté par IA.">
    <meta property="og:type"        content="website">
    <meta property="og:url"         content="<%= request.original_url %>">
    <meta property="og:image"        content="<%= image_url('og-image.png') %>">
    <meta property="og:image:width"  content="1200">
    <meta property="og:image:height" content="630">
    <%= favicon_link_tag 'icons/favicon-32x32.png', type: 'image/png', sizes: '32x32' %>
    <!-- <link rel="icon" href="/icon.svg" type="image/svg+xml"> -->
    <!-- <link rel="apple-touch-icon" href="/icon.png"> -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload", media: "all" %>
    <%= javascript_importmap_tags %>
    <link rel="manifest" href="<%= pwa_manifest_path %>">
    <%= render 'shared/ios_pwa_links' %>
  </head>

  <body>
    <header>
      <%= render "shared/navbar" %>
    </header>

    <main id="main-content">
      <%= yield %>
    </main>

    <%= render "shared/flashes" %>
  </body>
</html>
